# Cloudflare Pages headers — applied to every response from the deployed site.
# Edit-then-commit: changes go live with the next deploy.

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https://images.unsplash.com https://avatars.githubusercontent.com; connect-src 'self' https://api.github.com https://github.com https://unpkg.com https://api.web3forms.com https://cloudflareinsights.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self' https://github.com https://api.web3forms.com;

# Admin dashboard + CMS — noindex, no-cache
/admin/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-cache, no-store, must-revalidate

# Sveltia CMS shell (moved to /admin/cms/)
/admin/cms/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-cache, no-store, must-revalidate

# Static assets — long cache (filenames have content hash via Astro)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts — long cache + CORS for cross-origin font loads
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Uploads — Cloudflare _headers: khi nhiều rule khớp cùng path, RULE ĐỨNG SAU
# THẮNG → đặt fallback generic TRƯỚC, rule cụ thể SAU để override đúng.

# Fallback cho mọi upload (mặc định an toàn: cache vừa phải)
/uploads/*
  Cache-Control: public, max-age=86400, must-revalidate

# gen-script (tên file CỐ ĐỊNH: cat-*.webp, <slug>.webp) — có thể bị thay bằng
# ảnh chụp thật cùng tên → giữ cache ngắn để bản mới hiện trong ~1 ngày.
/uploads/products/*
  Cache-Control: public, max-age=86400
/uploads/blog/*
  Cache-Control: public, max-age=86400

# admin upload (tên file UNIQUE mỗi swap: <area>-<ts>-<rand>.webp) — cache vĩnh
# viễn an toàn vì URL cũ không bao giờ tái dùng (swap = filename mới).
/uploads/phong-mau/*
  Cache-Control: public, max-age=31536000, immutable
/uploads/combos/*
  Cache-Control: public, max-age=31536000, immutable
/uploads/hero/*
  Cache-Control: public, max-age=31536000, immutable
/uploads/projects/*
  Cache-Control: public, max-age=31536000, immutable
