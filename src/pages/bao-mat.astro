---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.yml';
import baoMat from '../data/bao-mat.yml';

const updated = baoMat.updated;
const sections = baoMat.sections ?? [];

// Thay token động từ site.yml → giữ privacy đồng bộ thông tin liên hệ.
const hotlineTel = `+84${String(site.hotline).replace(/\s|^0/g, '')}`;
const fill = (html: string) =>
  String(html ?? '')
    .replaceAll('{{email}}', site.email)
    .replaceAll('{{hotlineTel}}', hotlineTel)
    .replaceAll('{{hotline}}', site.hotline)
    .replaceAll('{{addressLine1}}', site.address.line1)
    .replaceAll('{{addressCity}}', site.address.city);
---
<BaseLayout
  title="Chính sách bảo mật — WOTU"
  description="Cách WOTU thu thập, sử dụng và bảo vệ dữ liệu cá nhân của khách hàng."
>
  <Nav variant="inner" />

  <article class="legal" style="padding: 140px var(--pad-x) var(--pad-section);">
    <header style="max-width: 64ch; margin: 0 auto 64px;">
      <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em; color: var(--earth); text-transform: uppercase; margin-bottom: 16px;">
        Cập nhật {updated}
      </div>
      <h1 style="font-family: var(--font-display); font-weight: 400; font-size: clamp(48px, 7vw, 96px); line-height: 1.0; color: var(--bark);">
        Chính sách <em style="font-style: italic; color: var(--earth);">bảo mật</em>
      </h1>
    </header>

    <div class="legal-body" style="max-width: 64ch; margin: 0 auto; font-family: var(--font-sans); font-size: 16px; line-height: 1.75; color: var(--ink);">
      {sections.map((s: { heading: string; body: string }) => (
        <Fragment>
          <h2>{s.heading}</h2>
          <Fragment set:html={fill(s.body)} />
        </Fragment>
      ))}
    </div>
  </article>

  <Footer />
</BaseLayout>

<style>
  .legal-body :global(h2) {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(24px, 2.6vw, 32px);
    line-height: 1.2;
    margin: 2.4em 0 0.6em;
    color: var(--bark);
  }
  .legal-body :global(p) { margin-bottom: 1.4em; }
  .legal-body :global(ul) {
    margin: 0 0 1.4em 1.5em;
    padding: 0;
  }
  .legal-body :global(li) { margin-bottom: 0.5em; }
  .legal-body :global(strong) { color: var(--bark); }
  .legal-body :global(code) {
    font-family: var(--font-mono);
    font-size: 14px;
    background: var(--linen);
    padding: 1px 6px;
    border-radius: 2px;
  }
</style>
