    display: flex; align-items: center; justify-content: space-between; gap: 10px;
    font-size: 14px;
  }
  .inspo-card .label span:first-child { background: rgba(0,0,0,.4); backdrop-filter: blur(6px); padding: 6px 12px; border-radius: 999px; font-weight: 600; color: var(--shop-bg); }
  .inspo-card .label .arrow { width: 36px; height: 36px; border-radius: 50%; background: var(--shop-bg); color: var(--shop-ink); display: grid; place-items: center; }

  /* ===== WHY ===== */
  .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .why-card {
    background: var(--shop-bg-card); border-radius: var(--shop-radius-lg);
    padding: 30px 26px; display: flex; flex-direction: column; gap: 14px;
    border: 1px solid color-mix(in oklab, var(--shop-line) 60%, transparent);
    transition: transform .3s ease;
  }
  .why-card:hover { transform: translateY(-4px); }
  .why-icon {
    width: 54px; height: 54px; border-radius: 16px;
    background: var(--shop-warm-soft); color: var(--shop-accent);
    display: grid; place-items: center;
  }
  .why-card:nth-child(2) .why-icon { background: var(--shop-accent-2-soft); color: var(--shop-accent-2); }
  .why-card:nth-child(3) .why-icon { background: color-mix(in oklab, var(--shop-yellow) 35%, white); color: #B4892B; }
  .why-card:nth-child(4) .why-icon { background: var(--shop-warm-soft); color: var(--shop-accent-deep); }
  .why-card h3 { font-family: var(--shop-serif); font-size: 24px; margin: 0; line-height: 1.1; font-weight: 400; }
  .why-card p { margin: 0; font-size: 14px; color: var(--shop-ink-soft); line-height: 1.55; }

  /* ===== REVIEWS ===== */
  .reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .review {
    background: var(--shop-bg-card); border-radius: var(--shop-radius-lg);
    padding: 28px; border: 1px solid color-mix(in oklab, var(--shop-line) 60%, transparent);
    display: flex; flex-direction: column; gap: 16px;
  }
  .review .stars { font-size: 18px; }
  .review p { margin: 0; font-family: var(--shop-serif); font-size: 22px; line-height: 1.3; color: var(--shop-ink); font-weight: 400; }
  .review .author { display: flex; align-items: center; gap: 12px; margin-top: auto; padding-top: 16px; border-top: 1px solid var(--shop-line); }
  .avatar { width: 44px; height: 44px; border-radius: 50%; background: var(--shop-warm-soft); display: grid; place-items: center; font-family: var(--shop-serif); font-size: 20px; color: var(--shop-accent); }
  .author .name { font-weight: 600; font-size: 14px; }
  .author .role { font-size: 12px; color: var(--shop-ink-soft); }

  /* ===== CTA STRIPE ===== */
  .cta {
    background: var(--shop-accent-2);
    border-radius: var(--shop-radius-xl);
    margin: 0 28px;
    padding: 70px 56px;
