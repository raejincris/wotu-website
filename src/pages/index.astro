  .combo-card.feature .combo-cat { color: color-mix(in oklab, var(--shop-bg) 80%, transparent); }
  .combo-card.feature .combo-title { font-size: 38px; color: var(--shop-bg); }
  .combo-card.feature .combo-title em { color: var(--shop-warm-soft); }
  .combo-card.feature .combo-includes { color: color-mix(in oklab, var(--shop-bg) 85%, transparent); min-height: 0; font-size: 14px; }
