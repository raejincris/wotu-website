  .product-meta { font-size: 12px; color: var(--shop-ink-soft); }
  .product-foot { display: flex; align-items: center; justify-content: space-between; padding-top: 10px; }
  .product-foot .price { font-size: 18px; }
  .stars { display: inline-flex; gap: 1px; color: var(--shop-accent); }

