---
import ShopLayout from '../layouts/ShopLayout.astro';
import Nav from '../components/shop/Nav.astro';
import Footer from '../components/shop/Footer.astro';
import Marquee from '../components/shop/Marquee.astro';
import Newsletter from '../components/Newsletter.astro';
import site from '../data/site.yml';
import shopHome from '../data/shop-home.yml';
import { resolveLayout } from '../lib/section-layout';

const phone = site.hotline;
const email = site.email;

const { hero, sections, combos, bestsellers, inspo, reviews } = shopHome as any;

// Bố cục: bật/tắt + thứ tự section (sửa qua admin "Bố cục trang").
const L = resolveLayout((shopHome as any).layout, [
  'combos', 'bestsellers', 'inspo', 'whyUs', 'reviews', 'cta', 'newsletter',
]);
const secStyle = (id: string) => `order:${L.order(id)};${L.on(id) ? '' : 'display:none;'}`;

// Map ảnh minh hoạ line-art (public/uploads/products/). Combo theo phòng,
// bestseller theo loại suy từ id, inspo theo phòng (cùng thứ tự combo trừ khách).
const ILLO = '/uploads/products';
const catFromId = (id: string) => {
  const k = (id || '').split('-')[1];
  return ['sofa', 'ban', 'ghe', 'giuong', 'tu', 'ke', 'den', 'tham'].includes(k) ? k : 'combo';
};
const inspoRooms = ['studio', 'phong-ngu', 'phong-an', 'lam-viec', 'tre-em'];
const whyIcons: Record<string, string> = {
  shield:  `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/>`,
  truck:   `<rect x="1" y="5" width="14" height="13" rx="1"/><polygon points="15 8 19 8 22 11 22 18 15 18"/><circle cx="6" cy="20" r="2"/><circle cx="18" cy="20" r="2"/>`,
  refresh: `<path d="M3 12a9 9 0 1 0 9-9"/><path d="M3 4v5h5"/>`,
  chat:    `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2Z"/>`,
};
---
<ShopLayout>
  <Nav />

  <!-- ====== HERO ====== -->
  <header class="hero shop-reveal">
    <div class="container hero-grid">
      <div>
        <div class="hero-eyebrow-row">
          <span class="pill"><span class="dot"></span> <span data-cms="hero.pill">{hero.pill}</span></span>
          <span class="eyebrow" data-cms="hero.eyebrow">{hero.eyebrow}</span>
        </div>
        <h1 set:html={hero.title} data-cms="hero.title" />
        <p class="hero-sub" data-cms="hero.sub">{hero.sub}</p>
        <div class="hero-actions">
          <a class="shop-btn shop-btn-primary" href="#combos"><span data-cms="hero.cta1">{hero.cta1}</span> <span class="arr">→</span></a>
          <a class="shop-btn shop-btn-ghost" href="#inspo" data-cms="hero.cta2">{hero.cta2}</a>
        </div>
        <div class="hero-meta">
          {hero.stats.map((s: any) => (
            <div>
              <div class="meta-num" set:html={s.num} />
              <div class="meta-label">{s.label}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="hero-visual">
        <div class="shop-ph"><span class="shop-ph-label">Phòng khách combo WOTU — 1600×2000</span></div>
        <img class="shop-illo" data-cms-img="hero.photo" src={hero.photo || `${ILLO}/combo-phong-khach.png`} alt={hero.photoAlt || 'Minh hoạ combo phòng khách WOTU'} loading="eager" fetchpriority="high" decoding="async" />
        <div class="sticker">
          {hero.sticker}<small>{hero.stickerSub}</small>
        </div>
        <div class="hero-tag">
          <div>
            <div class="l">{hero.tagLabel || 'Combo Phòng khách · Tổ Ấm'}</div>
            <div class="v"><s>{hero.tagPriceOld}</s>{hero.tagPriceNew}</div>
          </div>
          <a class="combo-cta" href={hero.tagHref || '/combo/to-am/'} aria-label="Xem combo">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7M9 7h8v8"/></svg>
          </a>
        </div>
      </div>
    </div>
  </header>

  <Marquee />

  <!-- Bố cục động: flex + CSS order cho bật/tắt & sắp xếp section -->
  <div class="cms-sections" style="display:flex; flex-direction:column;">

  <!-- ====== COMBOS ====== -->
  <section id="combos" class="shop-reveal" data-cms-section="combos" style={secStyle('combos')}>
    <div class="combos">
      <div class="section-head">
        <div>
          <span class="eyebrow" data-cms="sections.combos.eyebrow">{sections.combos.eyebrow}</span>
          <h2 set:html={sections.combos.heading} data-cms="sections.combos.heading" />
        </div>
        <div class="right" set:html={sections.combos.desc} data-cms="sections.combos.desc" />
      </div>

      <div class="combo-tabs">
        <button class="combo-tab" type="button" data-active="true" data-room="">Tất cả</button>
        <button class="combo-tab" type="button" data-room="phong-khach">Phòng khách</button>
        <button class="combo-tab" type="button" data-room="phong-ngu">Phòng ngủ</button>
        <button class="combo-tab" type="button" data-room="phong-an">Phòng ăn &amp; bếp</button>
        <button class="combo-tab" type="button" data-room="lam-viec">Làm việc</button>
        <button class="combo-tab" type="button" data-room="studio">Căn hộ studio</button>
        <button class="combo-tab" type="button" data-room="tre-em">Phòng trẻ em</button>
      </div>

      <div class="combo-grid shop-reveal-stagger" id="combo-grid">
        {combos.map((c, i) => (
          <article
            class={`combo-card${c.feature ? ' feature' : ''}`}
            data-room={c.room}
            data-id={c.id}
            data-price={c.price}
            data-name={`Combo ${c.nameEm}${c.nameTail ?? ''}`}
          >
            <div class="combo-img">
              <div class={`shop-ph ${c.tone}`}><span class="shop-ph-label">{c.placeholder}</span></div>
              <img class="shop-illo" src={c.photo || `${ILLO}/combo-${c.room}.png`} alt={`${c.photo ? '' : 'Minh hoạ '}${c.placeholder}`} loading="lazy" decoding="async" />
              {c.badge && (
                <span class={`combo-badge${c.badgeClass ? ' ' + c.badgeClass : ''}`} style={c.badgeStyle || undefined}>{c.badge}</span>
              )}
              {!c.feature && (
                <button class="combo-fav" type="button" data-fav={c.id} aria-label="Yêu thích">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3 5.97 5.97 0 0 0 12 5a5.97 5.97 0 0 0-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7Z"/></svg>
                </button>
              )}
            </div>
            <div class="combo-body">
              <span class="combo-cat" data-cms={`combos.${i}.cat`}>{c.cat}</span>
              <h3 class="combo-title">
                <span data-cms={`combos.${i}.name`}>{c.name}</span>{c.feature && <br/>} <em data-cms={`combos.${i}.nameEm`}>{c.nameEm}</em><span data-cms={`combos.${i}.nameTail`}>{c.nameTail}</span>
              </h3>
              <p class="combo-includes" data-cms={`combos.${i}.desc`}>{c.desc}</p>
              <div class="combo-foot">
                <div class="price"><s data-cms={`combos.${i}.priceOld`}>{c.priceOld}</s><span data-cms={`combos.${i}.priceNew`}>{c.priceNew}</span><small data-cms={`combos.${i}.priceNote`}>{c.priceNote}</small></div>
                <div class="combo-foot-actions">
                  <button class="combo-add" type="button" data-add aria-label="Thêm vào giỏ">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 5v14M5 12h14"/></svg>
                    <span>Giỏ</span>
                  </button>
                  <a class="combo-cta" href={c.href} aria-label="Xem combo">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7M9 7h8v8"/></svg>
                  </a>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>

      <p class="combo-empty" id="combo-empty" hidden>Chưa có combo phù hợp danh mục này — chúng tôi đang chuẩn bị. Để lại số ở <a href="#contact">phần liên hệ</a> để được tư vấn riêng.</p>

      <div style="text-align: center; margin-top: 44px;">
        <a class="shop-btn shop-btn-outline" href="/combo/"><span data-cms="sections.combos.ctaAll">{sections.combos.ctaAll}</span> <span class="arr">→</span></a>
      </div>
    </div>
  </section>

  <!-- ====== BESTSELLERS ====== -->
  <section id="shop" class="shop-reveal" data-cms-section="bestsellers" style={secStyle('bestsellers')}>
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow" data-cms="sections.bestsellers.eyebrow">{sections.bestsellers.eyebrow}</span>
          <h2 set:html={sections.bestsellers.heading} data-cms="sections.bestsellers.heading" />
        </div>
        <div class="right" set:html={sections.bestsellers.desc} data-cms="sections.bestsellers.desc" />
      </div>

      <div class="products-grid shop-reveal-stagger">
        {bestsellers.map((p, i) => (
          <article
            class="product-card"
            data-id={p.id}
            data-price={p.priceNum}
            data-name={p.name}
          >
            <a href={p.href} style="text-decoration: none; display: contents;">
              <div class="combo-img">
                <div class={`shop-ph ${p.tone}`}><span class="shop-ph-label">{p.placeholder}</span></div>
                <img class="shop-illo" src={`${ILLO}/cat-${catFromId(p.id)}.png`} alt={`Minh hoạ ${p.name}`} loading="lazy" decoding="async" />
              </div>
              <div class="product-body">
                <span class="product-meta" data-cms={`bestsellers.${i}.meta`}>{p.meta}</span>
                <h4 data-cms={`bestsellers.${i}.name`}>{p.name}</h4>
                <div class="product-foot">
                  <div class="price" data-cms={`bestsellers.${i}.price`}>{p.price}</div>
                  <span class="stars" data-cms={`bestsellers.${i}.stars`}>{p.stars}</span>
                </div>
              </div>
            </a>
            <button class="product-add" type="button" data-add aria-label={`Thêm ${p.name} vào giỏ`}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 5v14M5 12h14"/></svg>
              Thêm giỏ
            </button>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== INSPIRATION ====== -->
  <section id="inspo" class="shop-reveal" data-cms-section="inspo" style={secStyle('inspo')}>
    <div class="inspo">
      <div class="section-head">
        <div>
          <span class="eyebrow" data-cms="sections.inspo.eyebrow">{sections.inspo.eyebrow}</span>
          <h2 set:html={sections.inspo.heading} data-cms="sections.inspo.heading" />
        </div>
        <div class="right" set:html={sections.inspo.desc} data-cms="sections.inspo.desc" />
      </div>

      <div class="inspo-grid shop-reveal-stagger">
        {inspo.map((i, idx) => (
          <a class={`inspo-card${i.tall ? ' tall' : ''}`} href={i.href}>
            <div class="shop-ph dark"><span class="shop-ph-label">{i.placeholder}</span></div>
            <img class="shop-illo" src={`${ILLO}/combo-${inspoRooms[idx] ?? 'phong-khach'}.png`} alt={`Minh hoạ ${i.placeholder}`} loading="lazy" decoding="async" />
            <div class="label">
              <span>{i.label}</span>
              <span class="arrow">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7M9 7h8v8"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== WHY US ====== -->
  <section id="why" class="shop-reveal" data-cms-section="whyUs" style={secStyle('whyUs')}>
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow" data-cms="sections.whyUs.eyebrow">{sections.whyUs.eyebrow}</span>
          <h2 set:html={sections.whyUs.heading} data-cms="sections.whyUs.heading" />
        </div>
        <div class="right" set:html={sections.whyUs.desc} data-cms="sections.whyUs.desc" />
      </div>

      <div class="why-grid shop-reveal-stagger">
        {sections.whyUs.items.map((item: any) => (
          <div class="why-card">
            <div class="why-icon">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                   set:html={whyIcons[item.icon] ?? ''} />
            </div>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== REVIEWS ====== -->
  <section class="shop-reveal" data-cms-section="reviews" style={secStyle('reviews')}>
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow" data-cms="sections.reviews.eyebrow">{sections.reviews.eyebrow}</span>
          <h2 set:html={sections.reviews.heading} data-cms="sections.reviews.heading" />
        </div>
        <div class="right" set:html={sections.reviews.desc} data-cms="sections.reviews.desc" />
      </div>

      <div class="reviews-grid shop-reveal-stagger">
        {reviews.map((r, i) => (
          <div class="review">
            <span class="stars">★★★★★</span>
            <p>"<span data-cms={`reviews.${i}.quote`}>{r.quote}</span>"</p>
            <div class="author">
              <div class="avatar" data-cms={`reviews.${i}.initial`}>{r.initial}</div>
              <div>
                <div class="name" data-cms={`reviews.${i}.name`}>{r.name}</div>
                <div class="role" data-cms={`reviews.${i}.role`}>{r.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== CTA ====== -->
  <section id="contact" class="shop-reveal" data-cms-section="cta" style={`order:${L.order('cta')};${L.on('cta') ? '' : 'display:none;'} padding-bottom: 0;`}>
    <div class="cta">
      <div>
        <span class="eyebrow" style="color: color-mix(in oklab, var(--shop-bg) 80%, transparent);" data-cms="sections.cta.eyebrow">{sections.cta.eyebrow}</span>
        <h2 set:html={sections.cta.heading} data-cms="sections.cta.heading" />
        <p set:html={`${sections.cta.desc} Hoặc gọi trực tiếp <a href="tel:+84${phone.replace(/\s+/g, '').slice(1)}" style="text-decoration: underline;">${phone}</a> · email <a href="mailto:${email}" style="text-decoration: underline;">${email}</a>.`} />
      </div>
      <form
        class="cta-form"
        action="https://api.web3forms.com/submit"
        method="POST"
        data-shop-contact
      >
        <input type="hidden" name="access_key" value={site.forms.contactAccessKey} />
        <input type="hidden" name="subject" value="[WOTU shop] Đặt tư vấn combo" />
        <input type="hidden" name="from_name" value="WOTU Shop website" />
        <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="position: absolute; left: -9999px; opacity: 0;" aria-hidden="true" />
        <input type="tel" name="phone" placeholder="Số điện thoại của bạn" required />
        <button type="submit">Gọi tôi <span class="arr">→</span></button>
      </form>
    </div>
  </section>

  <div data-cms-section="newsletter" style={secStyle('newsletter')}>
    <Newsletter variant="shop" heading="Nhận ưu đãi & cảm hứng nội thất" />
  </div>

  </div><!-- /cms-sections -->
  <Footer />
</ShopLayout>

<style>
  /* ===== HERO ===== */
  .hero { padding: 40px 0 var(--shop-section-py); position: relative; }
  .hero-grid {
    display: grid; grid-template-columns: 1.05fr 1fr; gap: 48px;
    align-items: end;
  }
  .hero-eyebrow-row {
    display: flex; align-items: center; gap: 18px; margin-bottom: 28px;
    flex-wrap: wrap;
  }
  .pill {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--shop-warm-soft); color: var(--shop-accent-deep);
    padding: 7px 14px; border-radius: 999px; font-size: 12px; font-weight: 600;
  }
  .pill .dot {
    width: 6px; height: 6px; border-radius: 50%; background: var(--shop-accent);
    animation: shopPulse 1.6s ease-in-out infinite;
  }
  @keyframes shopPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: .4; transform: scale(1.3); }
  }
  .hero h1 {
    font-family: var(--shop-serif); font-weight: 400;
    font-size: clamp(48px, 7vw, 96px); line-height: 0.98; letter-spacing: -0.02em;
    margin: 0 0 26px;
  }
  /* em / .stroke đến từ set:html (hero.title) + live-patch → không có cid scope
     của Astro, nên phải :global() mới khớp. */
  .hero h1 :global(em) { font-style: italic; color: var(--shop-accent); }
  .hero h1 :global(.stroke) {
    -webkit-text-stroke: 1.5px var(--shop-ink); color: transparent;
    font-style: italic;
  }
  .hero-sub {
    font-size: 18px; color: var(--shop-ink-soft); max-width: 480px; line-height: 1.55;
    margin: 0 0 36px;
  }
  .hero-actions { display: flex; gap: 14px; align-items: center; margin-bottom: 44px; flex-wrap: wrap; }
  .hero-meta {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px;
    padding-top: 28px; border-top: 1px solid var(--shop-line);
  }
  .meta-num { font-family: var(--shop-serif); font-size: 36px; color: var(--shop-ink); line-height: 1; }
  .meta-num :global(sup) { font-size: 18px; color: var(--shop-accent); margin-left: 2px; }
  .meta-label { font-size: 12px; color: var(--shop-ink-soft); margin-top: 6px; letter-spacing: 0.04em; }

  .hero-visual {
    position: relative; aspect-ratio: 4 / 5;
    border-radius: var(--shop-radius-xl); overflow: hidden;
    background: var(--shop-bg-soft);
  }
  .hero-tag {
    position: absolute; left: 22px; bottom: 22px; right: 22px;
    background: color-mix(in oklab, var(--shop-bg-card) 85%, transparent);
    backdrop-filter: blur(8px);
    border-radius: 18px; padding: 16px 18px;
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    box-shadow: 0 8px 32px -12px rgba(0,0,0,.12);
  }
  .hero-tag .l { font-size: 12px; color: var(--shop-ink-soft); letter-spacing: .14em; text-transform: uppercase; }
  .hero-tag .v { font-family: var(--shop-serif); font-size: 22px; color: var(--shop-ink); }
  .hero-tag .v s { color: var(--shop-ink-soft); font-size: 14px; margin-right: 8px; font-family: var(--shop-sans); }
  .sticker {
    position: absolute; top: 22px; right: 22px;
    width: 110px; height: 110px; border-radius: 50%;
    background: var(--shop-accent); color: white;
    display: grid; place-items: center; text-align: center;
    font-family: var(--shop-serif); font-size: 22px; line-height: 1;
    transform: rotate(-12deg);
    box-shadow: 0 14px 30px -14px rgba(0,0,0,.4);
    animation: shopSway 4s ease-in-out infinite;
  }
  .sticker small { display: block; font-family: var(--shop-sans); font-size: 10px; letter-spacing: .2em; margin-top: 6px; font-weight: 700; }
  @keyframes shopSway {
    0%,100% { transform: rotate(-12deg) translateY(0); }
    50% { transform: rotate(-8deg) translateY(-6px); }
  }

  /* ===== COMBOS ===== */
  .combos {
    background: var(--shop-bg-soft);
    border-radius: var(--shop-radius-xl);
    padding: 80px 56px;
    margin: 0 28px;
  }
  .combo-tabs { display: flex; gap: 8px; flex-wrap: wrap; margin: 0 0 36px; }
  .combo-tab {
    padding: 10px 18px; border-radius: 999px;
    background: var(--shop-bg-card); color: var(--shop-ink-soft);
    font-size: 13px; font-weight: 600;
    border: 1px solid var(--shop-line);
    transition: all .2s ease;
    cursor: pointer;
  }
  .combo-tab[data-active="true"] {
    background: var(--shop-ink); color: var(--shop-bg); border-color: var(--shop-ink);
  }
  .combo-tab:hover { color: var(--shop-ink); }

  .combo-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .combo-card {
    background: var(--shop-bg-card); border-radius: var(--shop-radius-lg);
    overflow: hidden; display: flex; flex-direction: column;
    transition: transform .3s ease, box-shadow .3s ease;
    border: 1px solid color-mix(in oklab, var(--shop-line) 50%, transparent);
  }
  .combo-card:hover { transform: translateY(-6px); box-shadow: 0 24px 50px -20px rgba(58, 42, 30, .18); }
  .combo-img {
    aspect-ratio: 4/3; position: relative; overflow: hidden;
    background: var(--shop-warm-soft);
  }
  .combo-badge {
    position: absolute; top: 14px; left: 14px;
    background: var(--shop-ink); color: var(--shop-bg);
    padding: 6px 12px; border-radius: 999px;
    font-size: 11px; font-weight: 700; letter-spacing: .08em;
  }
  .combo-badge.sage { background: var(--shop-accent-2); color: white; }
  .combo-badge.terra { background: var(--shop-accent); color: white; }
  .combo-fav {
    position: absolute; top: 14px; right: 14px;
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--shop-bg-card); display: grid; place-items: center;
    transition: transform .2s ease;
    color: var(--shop-ink-soft);
  }
  .combo-fav:hover { transform: scale(1.1); color: var(--shop-accent); }
  .combo-body { padding: 22px; display: flex; flex-direction: column; gap: 14px; }
  .combo-cat { font-size: 11px; letter-spacing: .18em; color: var(--shop-ink-soft); text-transform: uppercase; font-weight: 600; }
  .combo-title { font-family: var(--shop-serif); font-size: 28px; line-height: 1.05; margin: 0; font-weight: 400; }
