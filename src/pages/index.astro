</style>

<script>
  import { addToCart, toggleFavorite, isFavorite, onChange, toast } from '../lib/shop-store';

  // ===== Combo tabs filter =====
  const tabs = document.querySelectorAll<HTMLButtonElement>('.combo-tab');
  const grid = document.getElementById('combo-grid');
  const empty = document.getElementById('combo-empty');

  function applyComboFilter(room: string): void {
    if (!grid) return;
    let visible = 0;
    grid.querySelectorAll<HTMLElement>('.combo-card').forEach((card) => {
      const match = !room || card.dataset.room === room;
      card.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    if (empty) empty.hidden = visible > 0;
  }

  tabs.forEach((btn) => {
    btn.addEventListener('click', () => {
      tabs.forEach((b) => (b.dataset.active = 'false'));
      btn.dataset.active = 'true';
      applyComboFilter(btn.dataset.room ?? '');
    });
  });

  // ===== Add to cart (combo + bestseller cards) =====
  document.querySelectorAll<HTMLButtonElement>('[data-add]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const card = btn.closest<HTMLElement>('[data-id]');
      if (!card) return;
      const id = card.dataset.id ?? '';
      const name = card.dataset.name ?? 'Sản phẩm';
      const price = Number(card.dataset.price ?? 0);
      addToCart({ id, name, price }, 1);
      toast(`✓ Đã thêm "${name}" vào giỏ`);
    });
  });

  // ===== Favorite toggle =====
  function syncFavUi(): void {
    document.querySelectorAll<HTMLButtonElement>('[data-fav]').forEach((b) => {
      const id = b.dataset.fav ?? '';
      b.dataset.active = isFavorite(id) ? 'true' : 'false';
    });
  }
  document.querySelectorAll<HTMLButtonElement>('[data-fav]').forEach((b) => {
    b.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const id = b.dataset.fav ?? '';
      const nowOn = toggleFavorite(id);
      b.dataset.active = nowOn ? 'true' : 'false';
      toast(nowOn ? '♥ Đã lưu vào yêu thích' : 'Đã bỏ yêu thích', { type: 'info' });
    });
  });
  syncFavUi();
  onChange(syncFavUi);

  // ===== Contact form =====
  const form = document.querySelector<HTMLFormElement>('form[data-shop-contact]');
  form?.addEventListener('submit', () => {
    const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    if (btn) {
      setTimeout(() => {
        btn.innerHTML = 'Đã nhận ✓';
        const input = form.querySelector<HTMLInputElement>('input[type="tel"]');
        if (input) input.value = '';
      }, 100);
    }
  });
</script>
