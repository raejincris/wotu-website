    .combos, .inspo, .cta { margin: 0 12px; padding: 50px 22px; }
    .hero-meta { grid-template-columns: 1fr; gap: 12px; }
    .inspo-grid { grid-template-columns: 1fr; grid-template-rows: repeat(5, 200px); }
    .inspo-card.tall { grid-column: span 1; }
