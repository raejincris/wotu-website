  .cta h2 { font-family: var(--shop-serif); font-weight: 400; font-size: clamp(36px, 5vw, 56px); line-height: 1; margin: 0; letter-spacing: -.015em; color: var(--shop-bg); }
  .cta h2 em { font-style: italic; color: var(--shop-warm-soft); }
  .cta p { color: color-mix(in oklab, var(--shop-bg) 85%, transparent); margin: 18px 0 0; max-width: 540px; line-height: 1.6; }
