  href: string;
  placeholder: string;
  tone: '' | 'sage';
  badges?: { label: string; cls?: 'accent' | 'sage' | 'dark' }[];
  cat: string;
  catKey: 'sofa' | 'ban' | 'ghe' | 'giuong' | 'tu' | 'ke' | 'den' | 'tham';
  room: 'phong-khach' | 'phong-ngu' | 'phong-an' | 'lam-viec' | 'tre-em';
  id: string;
  name: string;
  nameEm: string;
  nameTail?: string;
  /** Color swatches displayed on card (hex). */
  colors?: string[];
  extraColors?: number;
  priceOld?: string;
  price: string;
  priceNum: number;
  rating: string;
  ratingNum: number;
  reviews: number;
  /** Filter tags: union of material/color/status keys. Tag selectors xem sidebar. */
  tags: string[];
}

