  if (qCat) state.cat = qCat;
  if (qRoom) state.rooms.add(qRoom);

  const grid = document.getElementById('grid');
  const resultCount = document.querySelector<HTMLElement>('.tb-controls span b');
  const sortSel = document.querySelector<HTMLSelectElement>('.tb-controls select');
  const priceMinInput = document.querySelector<HTMLInputElement>('.range-inputs input:first-child');
  const priceMaxInput = document.querySelector<HTMLInputElement>('.range-inputs input:last-child');
  const chipsBox = document.querySelector<HTMLElement>('.tb-chips');
  const loadMoreBtn = document.querySelector<HTMLAnchorElement>('.pager .shop-btn-outline');
  const pagerInfo = document.querySelector<HTMLElement>('.pager .info');
  const TOTAL = grid?.querySelectorAll('.product-card-item').length ?? 0;

  function parsePrice(s: string): number {
    return Number(s.replace(/[^\d]/g, '')) || 0;
  }

  function renderChips(): void {
    if (!chipsBox) return;
    // Find existing chips wrapper sentinel — preserve "Lọc đang dùng:" label + "Xoá tất cả" link
    chipsBox.querySelectorAll<HTMLElement>('.chip').forEach((c) => c.remove());
    const label = chipsBox.querySelector('span');
    const clearLink = chipsBox.querySelector('a');

    const items: { label: string; remove: () => void }[] = [];
    if (state.cat) items.push({ label: CAT_LABELS[state.cat] ?? state.cat, remove: () => setActiveCat('') });
    state.rooms.forEach((r) => items.push({ label: ROOM_LABELS[r] ?? r, remove: () => { state.rooms.delete(r); syncCheckbox('room', r, false); applyFilter(); } }));
    state.tags.forEach((t) => items.push({ label: TAG_LABELS[t] ?? t, remove: () => { state.tags.delete(t); syncCheckbox('tag', t, false); applyFilter(); } }));
    if (state.priceMin > 0 || state.priceMax < Number.POSITIVE_INFINITY) {
      const fmt = (n: number) => new Intl.NumberFormat('vi-VN').format(n);
      const lbl =
        state.priceMin > 0 && state.priceMax < Number.POSITIVE_INFINITY
          ? `${fmt(state.priceMin)} – ${fmt(state.priceMax)}đ`
          : state.priceMin > 0
            ? `Từ ${fmt(state.priceMin)}đ`
            : `Dưới ${fmt(state.priceMax)}đ`;
      items.push({
        label: lbl,
        remove: () => {
          state.priceMin = 0; state.priceMax = Number.POSITIVE_INFINITY;
          if (priceMinInput) priceMinInput.value = '';
          if (priceMaxInput) priceMaxInput.value = '';
          applyFilter();
        },
      });
    }

    items.forEach((it) => {
      const chip = document.createElement('span');
      chip.className = 'chip active';
      chip.innerHTML = `${it.label} <button class="x" type="button" aria-label="Bỏ">×</button>`;
      chip.querySelector<HTMLButtonElement>('.x')?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        it.remove();
      });
      if (clearLink) chipsBox.insertBefore(chip, clearLink);
      else chipsBox.appendChild(chip);
    });

    // Show/hide "Lọc đang dùng:" + "Xoá tất cả" based on whether any filter active
    const hasAny = items.length > 0;
    if (label) label.style.display = hasAny ? '' : 'none';
    if (clearLink) (clearLink as HTMLAnchorElement).style.display = hasAny ? '' : 'none';
  }

  function syncCheckbox(kind: 'room' | 'tag', key: string, checked: boolean): void {
    const selector = kind === 'room' ? `[data-filter-room="${key}"]` : `[data-filter-tag="${key}"]`;
    const cb = document.querySelector<HTMLInputElement>(selector);
    if (cb) cb.checked = checked;
  }

  function clearAll(): void {
    state.cat = '';
    state.rooms.clear();
    state.tags.clear();
    state.priceMin = 0;
    state.priceMax = Number.POSITIVE_INFINITY;
    document.querySelectorAll<HTMLInputElement>('[data-filter-room], [data-filter-tag]').forEach((cb) => (cb.checked = false));
    if (priceMinInput) priceMinInput.value = '';
    if (priceMaxInput) priceMaxInput.value = '';
    document.querySelectorAll<HTMLButtonElement>('.cat-tile').forEach((b) => (b.dataset.active = b.dataset.cat === '' ? 'true' : 'false'));
    applyFilter();
  }

  function applyFilter(): void {
    if (!grid) return;
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.product-card-item'));
    let visible = 0;
    cards.forEach((card) => {
      const cat = card.dataset.cat ?? '';
      const room = card.dataset.room ?? '';
      const price = Number(card.dataset.price ?? 0);
      const tags = (card.dataset.tags ?? '').split(/\s+/).filter(Boolean);
      const matchCat = !state.cat || cat === state.cat;
      const matchRoom = state.rooms.size === 0 || state.rooms.has(room);
      const matchPrice = price >= state.priceMin && price <= state.priceMax;
      // Tags: phải match TẤT CẢ tag đã chọn (AND across tag types — material+color+status có thể đan xen)
      const matchTags = state.tags.size === 0 || Array.from(state.tags).every((t) => tags.includes(t));
      const show = matchCat && matchRoom && matchPrice && matchTags;
      card.hidden = !show;
      if (show) visible++;
    });
    if (resultCount) resultCount.textContent = String(visible);
    if (pagerInfo) {
      const total = TOTAL;
      pagerInfo.innerHTML = `Hiển thị <b style="color: var(--shop-ink);">${visible}</b> trong tổng <b style="color: var(--shop-ink);">${total}</b> sản phẩm`;
    }
    if (loadMoreBtn) {
      loadMoreBtn.textContent = 'Đã hiển thị tất cả';
      (loadMoreBtn as HTMLAnchorElement).style.opacity = '0.5';
      (loadMoreBtn as HTMLAnchorElement).style.pointerEvents = 'none';
    }
    renderChips();

    // Sort
    const visCards = cards.filter((c) => !c.hidden);
    visCards.sort((a, b) => {
      const pa = Number(a.dataset.price ?? 0);
      const pb = Number(b.dataset.price ?? 0);
      const ra = Number(a.dataset.rating ?? 0);
      const rb = Number(b.dataset.rating ?? 0);
      switch (state.sort) {
        case 'price-asc': return pa - pb;
        case 'price-desc': return pb - pa;
        case 'rating': return rb - ra;
        default: return 0;
      }
    });
    if (state.sort !== 'relevant') visCards.forEach((c) => grid.appendChild(c));
  }

  // ===== Cat tile single-select =====
  const catTiles = document.querySelectorAll<HTMLButtonElement>('.cat-tile');
  function setActiveCat(key: string): void {
    state.cat = key;
    catTiles.forEach((x) => (x.dataset.active = x.dataset.cat === key ? 'true' : 'false'));
    applyFilter();
  }
  catTiles.forEach((t) => {
    t.addEventListener('click', () => setActiveCat(t.dataset.cat ?? ''));
  });
  if (qCat) setActiveCat(qCat);

  // ===== Room checkboxes =====
  document.querySelectorAll<HTMLInputElement>('[data-filter-room]').forEach((cb) => {
    const key = cb.dataset.filterRoom ?? '';
    if (state.rooms.has(key)) cb.checked = true;
    if (cb.checked) state.rooms.add(key);
    cb.addEventListener('change', () => {
      if (cb.checked) state.rooms.add(key);
      else state.rooms.delete(key);
      applyFilter();
    });
  });

  // ===== Tag (material/color/status) checkboxes =====
  document.querySelectorAll<HTMLInputElement>('[data-filter-tag]').forEach((cb) => {
    const key = cb.dataset.filterTag ?? '';
    if (cb.checked) state.tags.add(key);
    cb.addEventListener('change', () => {
      if (cb.checked) state.tags.add(key);
      else state.tags.delete(key);
      applyFilter();
    });
  });

  // ===== "Xoá tất cả" links =====
  document.querySelectorAll<HTMLAnchorElement>('.filters-head a, .tb-chips a').forEach((a) => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      clearAll();
    });
  });

  // ===== Sort dropdown =====
  sortSel?.addEventListener('change', () => {
    const opt = sortSel.selectedOptions[0]?.text ?? '';
    if (opt.includes('thấp')) state.sort = 'price-asc';
    else if (opt.includes('cao →')) state.sort = 'price-desc';
    else if (opt.includes('Đánh giá')) state.sort = 'rating';
    else state.sort = 'relevant';
    applyFilter();
  });

  // ===== Price range inputs =====
  function syncPriceRange(): void {
    if (priceMinInput) state.priceMin = parsePrice(priceMinInput.value);
    if (priceMaxInput) state.priceMax = parsePrice(priceMaxInput.value) || Number.POSITIVE_INFINITY;
    applyFilter();
  }
  priceMinInput?.addEventListener('change', syncPriceRange);
  priceMaxInput?.addEventListener('change', syncPriceRange);
  syncPriceRange();

  // ===== View toggle =====
  document.querySelectorAll<HTMLButtonElement>('.view-toggle button').forEach((b) =>
    b.addEventListener('click', () => {
      document.querySelectorAll<HTMLButtonElement>('.view-toggle button').forEach((x) => x.classList.remove('active'));
      b.classList.add('active');
      if (grid) grid.dataset.view = b.dataset.view ?? '3col';
    }),
  );

  // Chips are now rendered dynamically by renderChips() inside applyFilter().

  // ===== Add to cart =====
  document.querySelectorAll<HTMLButtonElement>('[data-add]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const card = btn.closest<HTMLElement>('[data-id]');
      if (!card) return;
      addToCart(
        {
          id: card.dataset.id ?? '',
          name: card.dataset.name ?? 'Sản phẩm',
          price: Number(card.dataset.price ?? 0),
        },
        1,
      );
      toast(`✓ Đã thêm "${card.dataset.name}" vào giỏ`);
    });
  });

  // ===== Favorite toggle =====
  function syncFavUi(): void {
    document.querySelectorAll<HTMLButtonElement>('[data-fav]').forEach((b) => {
      const id = b.dataset.fav ?? '';
      b.dataset.active = isFavorite(id) ? 'true' : 'false';
    });
  }
  document.querySelectorAll<HTMLButtonElement>('[data-fav]').forEach((b) => {
    b.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const id = b.dataset.fav ?? '';
      const nowOn = toggleFavorite(id);
      b.dataset.active = nowOn ? 'true' : 'false';
      toast(nowOn ? '♥ Đã lưu vào yêu thích' : 'Đã bỏ yêu thích', { type: 'info' });
    });
  });
  syncFavUi();
  onChange(syncFavUi);

  // Initial render
  applyFilter();
</script>
