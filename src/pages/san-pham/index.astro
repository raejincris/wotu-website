---
<ShopLayout title="Tất cả sản phẩm — WOTU Nội thất Việt" description="Cửa hàng nội thất WOTU — sofa, bàn ăn, giường, tủ, kệ, đèn. 184 sản phẩm gỗ tự nhiên, giao 48h tại Quy Nhơn và các tỉnh lân cận.">
  <Nav active="Sản phẩm" />

  <!-- Crumb -->
  <div class="container crumb">
    <div class="crumb-list">
      <a href="/">Trang chủ</a>
      <span class="sep">/</span>
      <span class="here">Tất cả sản phẩm</span>
    </div>
  </div>

  <!-- Page header -->
  <header class="ph-head container shop-reveal">
    <div class="ph-head-grid">
      <div>
        <span class="eyebrow">Cửa hàng — bộ sưu tập 2026</span>
        <h1>Tất cả <em>sản phẩm</em>.</h1>
      </div>
      <div>
        <p class="meta">
          WOTU hiện có <b>184 sản phẩm</b> trải đều 9 nhóm — từ sofa, bàn ăn, giường đến phụ kiện trang trí. Xưởng tại Quy Nhơn, giao tận nhà trong vùng Bình Định &amp; các tỉnh lân cận trong 48 giờ.
        </p>
        <div class="meta-row">
          <div><b>184</b><span>sản phẩm</span></div>
          <div><b>24</b><span>bộ sưu tập</span></div>
          <div><b>9</b><span>danh mục</span></div>
          <div><b>4.8★</b><span>đánh giá TB</span></div>
        </div>
      </div>
    </div>
  </header>

  <!-- Category tiles -->
  <section class="cat-tiles container shop-reveal">
    <div class="cat-tiles-track">
      {cats.map((c) => (
        <button class="cat-tile" type="button" data-active={c.active ? 'true' : 'false'} data-cat={c.key}>
          <span class="ic">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              {c.icon.split('|').map((part) => {
                if (part.startsWith('rect:')) {
                  const [x, y, w, h, r] = part.slice(5).split(' ');
                  return <rect x={x} y={y} width={w} height={h} rx={r} />;
                }
                return <path d={part} />;
              })}
            </svg>
          </span>
          <span class="name">{c.name}</span>
          <span class="n">{c.count}</span>
        </button>
      ))}
    </div>
  </section>

  <!-- Toolbar sticky -->
  <div class="toolbar">
    <div class="container tb-inner">
      <div class="tb-chips">
        <span style="font-size: 12px; color: var(--shop-ink-soft); font-weight: 600; letter-spacing: .04em;">Lọc đang dùng:</span>
        <a href="#" style="font-size: 12px; color: var(--shop-accent); font-weight: 600;">Xoá tất cả</a>
      </div>
      <div class="tb-controls">
        <span style="color: var(--shop-ink-soft);"><b style="color: var(--shop-ink); font-weight: 600;">42</b> kết quả</span>
        <select aria-label="Sắp xếp">
          <option>Liên quan nhất</option>
          <option>Bán chạy nhất</option>
          <option>Đánh giá cao nhất</option>
          <option>Giá thấp → cao</option>
          <option>Giá cao → thấp</option>
          <option>Mới nhất</option>
        </select>
        <div class="view-toggle">
          <button class="active" type="button" data-view="3col" aria-label="3 cột">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="6" height="18"/><rect x="9.5" y="3" width="5" height="18"/><rect x="15" y="3" width="6" height="18"/></svg>
          </button>
          <button type="button" data-view="4col" aria-label="4 cột">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="4" height="18"/><rect x="8" y="3" width="4" height="18"/><rect x="13" y="3" width="4" height="18"/><rect x="18" y="3" width="3" height="18"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Shop layout: filters + grid -->
  <main class="shop container">
    <aside class="filters">
      <div class="filters-head">
        <h3>Bộ lọc</h3>
        <a href="#">Xoá tất cả</a>
      </div>

      <!-- "Danh mục" duplicate với cat tiles trên cùng (cat-tiles section).
           Reviewer feedback: bỏ sidebar version để tránh state desync — user
           dùng cat tiles cho category, sidebar chỉ giữ filter còn lại. -->

      <details class="fgrp" open>
        <summary>Theo phòng</summary>
        <div class="fgrp-body">
          {filters.rooms.map((f) => (
            <label class="check-row">
              <span><input type="checkbox" data-filter-room={f.key} checked={f.checked} />{f.label}</span>
              <span class="count">{f.count}</span>
            </label>
          ))}
        </div>
      </details>

      <details class="fgrp" open>
        <summary>Khoảng giá</summary>
        <div class="fgrp-body range">
          <div class="range-track">
            <div class="range-fill"></div>
            <div class="range-thumb lo"></div>
            <div class="range-thumb hi"></div>
          </div>
          <div class="range-inputs">
            <input type="text" value="500.000đ" />
            <input type="text" value="9.500.000đ" />
          </div>
        </div>
      </details>

      <details class="fgrp">
        <summary>Chất liệu</summary>
        <div class="fgrp-body">
          {filters.materials.map((f) => (
            <label class="check-row">
              <span><input type="checkbox" data-filter-tag={f.key} checked={f.checked} />{f.label}</span>
              <span class="count">{f.count}</span>
            </label>
          ))}
        </div>
      </details>

      <details class="fgrp">
        <summary>Màu sắc</summary>
        <div class="fgrp-body">
          {filters.colors.map((f) => (
            <label class="check-row">
              <span><input type="checkbox" data-filter-tag={f.key} /><span class="color-dot" style={`background:${f.dot}`}></span>{f.label}</span>
              <span class="count">{f.count}</span>
            </label>
          ))}
        </div>
      </details>

      <details class="fgrp">
        <summary>Trạng thái</summary>
        <div class="fgrp-body">
          {filters.status.map((f) => (
            <label class="check-row">
              <span><input type="checkbox" data-filter-tag={f.key} />{f.label}</span>
              <span class="count">{f.count}</span>
            </label>
          ))}
        </div>
      </details>

      <div style="padding-top: 20px;">
        <a class="shop-btn shop-btn-primary" href="#" style="width: 100%; justify-content: center;">Áp dụng (42)</a>
      </div>
    </aside>

    <!-- GRID -->
    <div>
      <div class="grid shop-reveal-stagger" id="grid" data-view="3col">

        <!-- Feature card -->
        <a class="card feature" href="/combo/to-am/">
          <div class="card-img">
            <div class="shop-ph"><span class="shop-ph-label">Combo Tổ Ấm phòng khách</span></div>
            <div class="card-badges"><span class="b-tag" style="background: var(--shop-bg); color: var(--shop-ink);">★ BESTSELLER</span></div>
          </div>
          <div class="card-body">
            <span class="card-meta">Combo phòng khách · 4 món</span>
            <h4>Combo <em>Tổ Ấm</em></h4>
            <p class="desc">Sofa văng 3 chỗ · bàn trà gỗ sồi · kệ TV 1m8 · thảm dệt tay. Mua trọn combo tiết kiệm 10 triệu so với mua lẻ.</p>
            <div class="card-foot">
              <div class="card-price"><s>28.900.000đ</s>18.900.000đ</div>
            </div>
            <span class="shop-btn" style="margin-top: 6px; padding: 14px 22px; font-size: 14px;">Xem combo Tổ Ấm <span class="arr">→</span></span>
          </div>
        </a>

        {products.map((p) => (
          <article
            class="card product-card-item"
            data-id={p.id}
            data-cat={p.catKey}
            data-room={p.room}
            data-price={p.priceNum}
            data-rating={p.ratingNum}
            data-name={`${p.name} ${p.nameEm}${p.nameTail ?? ''}`.trim()}
            data-tags={(p.tags ?? []).join(' ')}
          >
            <a href={p.href} style="text-decoration: none; color: inherit; display: contents;">
              <div class="card-img">
                <div class={`shop-ph ${p.tone}`}><span class="shop-ph-label">{p.placeholder}</span></div>
                {p.badges && (
                  <div class="card-badges">
                    {p.badges.map((b) => <span class={`b-tag${b.cls ? ' ' + b.cls : ''}`}>{b.label}</span>)}
                  </div>
                )}
              </div>
              <div class="card-body">
                <span class="card-meta">{p.cat}</span>
                <h4>{p.name} <em>{p.nameEm}</em>{p.nameTail}</h4>
                {p.colors && (
                  <span class="card-color-row" style="margin-top: 2px;">
                    {p.colors.map((c) => <span style={`background:${c}`}></span>)}
                    {p.extraColors && <span style={`background:var(--shop-bg-soft); color:var(--shop-ink-soft); font-size:8px; display:grid; place-items:center;`}>+{p.extraColors}</span>}
                  </span>
                )}
                <div class="card-foot">
