  };

  // ===== State =====
  const state = {
    cat: '',
    rooms: new Set<string>(),
    tags: new Set<string>(), // material + color + status (cùng key space)
    sort: 'relevant',
    priceMin: 0,
    priceMax: Number.POSITIVE_INFINITY,
  };

  const url = new URL(window.location.href);
  const qCat = url.searchParams.get('cat');
