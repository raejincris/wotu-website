  { id: 'combo-to-am',         name: 'Combo Tổ Ấm',                      meta: 'Phòng khách',             price: 18_900_000, priceLabel: '18.900.000đ', href: '/combo/to-am/',           tone: '',     placeholder: 'Combo Tổ Ấm' },
  { id: 'combo-an-yen',        name: 'Combo An Yên',                     meta: 'Phòng ngủ master',        price: 22_500_000, priceLabel: '22.500.000đ', href: '/san-pham/?room=phong-ngu',tone: 'sage', placeholder: 'Combo An Yên' },
  { id: 'combo-sum-vay',       name: 'Combo Sum Vầy',                    meta: 'Phòng ăn · 6 chỗ',        price: 12_800_000, priceLabel: '12.800.000đ', href: '/san-pham/?room=phong-an', tone: '',     placeholder: 'Combo Sum Vầy' },
