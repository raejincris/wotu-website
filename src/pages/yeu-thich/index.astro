---
/* Wishlist page — render từ localStorage favorites client-side.
 * Catalog của shop là static, nên chúng ta hardcode metadata cho từng favorite ID
 * trong cùng dataset để tra cứu khi cần render thẻ.
 */
import ShopLayout from '../../layouts/ShopLayout.astro';
import SplitWords from '../../components/SplitWords.astro';
import Nav from '../../components/shop/Nav.astro';
import Footer from '../../components/shop/Footer.astro';
import { catalogJson } from '../../lib/shop-catalog';
const catalogJsonStr = catalogJson();
---
<ShopLayout title="Yêu thích — WOTU" description="Sản phẩm và combo bạn đã đánh dấu yêu thích. Lưu trong trình duyệt — không cần đăng nhập.">
  <Nav />

  <div class="container crumb">
    <div class="crumb-list">
      <a href="/">Trang chủ</a>
      <span class="sep">/</span>
      <span class="here">Yêu thích</span>
    </div>
  </div>

  <header class="wl-head container shop-reveal">
    <span class="eyebrow reveal" data-reveal style="--rev-delay: 0ms">Của riêng bạn</span>
    <SplitWords tag="h1" text="Yêu thích <em>của bạn</em>." base={80} step={50} />
    <p class="wl-sub reveal" data-reveal style="--rev-delay: 160ms">Mọi sản phẩm và combo bạn đánh dấu ♥ trên các trang khác sẽ xuất hiện ở đây. Danh sách lưu trong trình duyệt — không cần đăng nhập, đồng bộ tự động giữa các tab.</p>
  </header>

  <section class="container shop-reveal" style="padding: 24px 28px var(--shop-section-py);">
    <div id="wl-empty" class="wl-empty" hidden>
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
        <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3 5.97 5.97 0 0 0 12 5a5.97 5.97 0 0 0-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7Z"/>
      </svg>
      <h2>Chưa có sản phẩm yêu thích</h2>
      <p>Khi bạn click vào biểu tượng ♥ trên các sản phẩm hoặc combo, nó sẽ xuất hiện ở đây để dễ tìm lại.</p>
      <div class="wl-empty-actions">
        <a class="shop-btn shop-btn-primary" href="/san-pham/">Khám phá sản phẩm <span class="arr">→</span></a>
        <a class="shop-btn shop-btn-outline" href="/#combos">Xem combo</a>
      </div>
    </div>

    <div id="wl-grid" class="wl-grid" hidden></div>

    <div id="wl-actions" class="wl-actions" hidden>
      <span id="wl-count" class="wl-count">0 sản phẩm</span>
      <div class="wl-actions-btns">
        <button type="button" class="shop-btn shop-btn-primary" id="wl-add-all">Thêm hết vào giỏ</button>
        <button type="button" class="wl-clear" id="wl-clear">Xoá tất cả</button>
      </div>
    </div>
  </section>

  <Footer />
</ShopLayout>

<script is:inline define:vars={{ catalogJsonStr }}>
  window.__wotuCatalog = window.__wotuCatalog || JSON.parse(catalogJsonStr);
</script>

<script>
  import { getFavorites, toggleFavorite, clearFavorites, addToCart, addManyToCart, onChange, toast, formatPrice } from '../../lib/shop-store';

  interface CatalogEntry {
    id: string;
    name: string;
    meta: string;
    price: number;
    priceLabel: string;
    href: string;
    illo: string;
    placeholder: string;
  }

  const catalog: CatalogEntry[] =
    (window as unknown as { __wotuCatalog?: CatalogEntry[] }).__wotuCatalog ?? [];
  const byId = new Map(catalog.map((c) => [c.id, c]));

  const grid = document.getElementById('wl-grid');
  const empty = document.getElementById('wl-empty');
  const actions = document.getElementById('wl-actions');
  const count = document.getElementById('wl-count');
  const clearBtn = document.getElementById('wl-clear');

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));
  }

  function render(): void {
    if (!grid || !empty || !actions || !count) return;
    const ids = getFavorites();
    const items = ids
      .map((id) => byId.get(id))
      .filter((x): x is CatalogEntry => !!x);

    if (items.length === 0) {
      grid.hidden = true;
      empty.hidden = false;
      actions.hidden = true;
      return;
    }
    grid.hidden = false;
    empty.hidden = true;
    actions.hidden = false;
    count.textContent = `${items.length} sản phẩm yêu thích`;

    grid.innerHTML = items
      .map(
        (it) => `
          <article class="wl-card" data-id="${escapeHtml(it.id)}">
            <a href="${escapeHtml(it.href)}" class="wl-link">
              <div class="wl-img">
                <div class="shop-ph"><span class="shop-ph-label">${escapeHtml(it.placeholder)}</span></div>
                <img class="shop-illo" src="${escapeHtml(it.illo)}" alt="${escapeHtml(it.name)}" loading="lazy" decoding="async" />
              </div>
              <div class="wl-body">
                <span class="wl-meta">${escapeHtml(it.meta)}</span>
                <h3>${escapeHtml(it.name)}</h3>
                <div class="wl-price">${escapeHtml(it.priceLabel)}</div>
              </div>
            </a>
            <div class="wl-actions-row">
              <button type="button" class="wl-add" data-act="add">+ Thêm giỏ</button>
              <button type="button" class="wl-remove" data-act="remove" aria-label="Bỏ khỏi yêu thích">♥</button>
            </div>
          </article>
        `,
      )
      .join('');

    grid.querySelectorAll<HTMLElement>('.wl-card').forEach((card) => {
      const id = card.dataset.id ?? '';
      const item = byId.get(id);
      if (!item) return;
      card.querySelector<HTMLButtonElement>('[data-act="add"]')?.addEventListener('click', () => {
        addToCart({ id: item.id, name: item.name, price: item.price }, 1);
        toast(`✓ Đã thêm "${item.name}" vào giỏ`);
      });
      card.querySelector<HTMLButtonElement>('[data-act="remove"]')?.addEventListener('click', () => {
        toggleFavorite(item.id);
        toast('Đã bỏ khỏi yêu thích', { type: 'info' });
      });
    });
  }

  const addAllBtn = document.getElementById('wl-add-all');
  addAllBtn?.addEventListener('click', () => {
    const ids = getFavorites();
    const items = ids.map((id) => byId.get(id)).filter((x): x is CatalogEntry => !!x);
    if (!items.length) return;
    addManyToCart(items.map((it) => ({ id: it.id, name: it.name, price: it.price })));
    toast(`✓ Đã thêm ${items.length} sản phẩm vào giỏ`);
    (window as unknown as { __wotuOpenCart?: () => void }).__wotuOpenCart?.();
  });

  clearBtn?.addEventListener('click', () => {
    if (!confirm('Xoá toàn bộ danh sách yêu thích?')) return;
    clearFavorites();
  });

  render();
  onChange(render);
</script>

<style>
  .crumb { padding: 22px 0 6px; }
  .crumb-list { display: flex; flex-wrap: wrap; gap: 8px; font-size: 13px; color: var(--shop-ink-soft); align-items: center; }
  .crumb-list a:hover { color: var(--shop-accent); }
  .crumb-list .sep { opacity: .5; }
  .crumb-list .here { color: var(--shop-ink); font-weight: 600; }

  .wl-head { padding: 14px 28px 36px; max-width: 880px; }
  .wl-head :global(h1) {
    font-family: var(--shop-serif); font-weight: 400;
    font-size: clamp(44px, 6vw, 76px); line-height: 0.98; letter-spacing: -.02em;
    margin: 14px 0 18px;
  }
  .wl-head :global(h1 em) { font-style: italic; color: var(--shop-accent); }
  .wl-sub { font-size: 16px; color: var(--shop-ink-soft); line-height: 1.55; max-width: 60ch; margin: 0; }

  .wl-empty {
    text-align: center; padding: 80px 24px;
    border: 1px dashed var(--shop-line); border-radius: var(--shop-radius-xl);
    color: var(--shop-ink-soft);
    max-width: 560px; margin: 0 auto;
  }
  .wl-empty svg { color: var(--shop-warm-soft); margin-bottom: 24px; }
  .wl-empty h2 { font-family: var(--shop-serif); font-weight: 400; font-size: 32px; margin: 0 0 12px; color: var(--shop-ink); }
  .wl-empty p { font-size: 15px; line-height: 1.55; max-width: 38ch; margin: 0 auto 28px; }
  .wl-empty-actions { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }

  .wl-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px;
  }
  /* Card render động qua innerHTML → KHÔNG có data-astro-cid, nên style phải
     :global() mới áp được (đây là bug cũ khiến card không có style khi có favorite). */
  :global(.wl-card) {
    background: var(--shop-bg-card); border-radius: var(--shop-radius-lg);
    overflow: hidden; display: flex; flex-direction: column;
    border: 1px solid color-mix(in oklab, var(--shop-line) 60%, transparent);
    transition: transform .25s, box-shadow .25s;
    position: relative;
  }
  :global(.wl-card:hover) { transform: translateY(-4px); box-shadow: 0 18px 36px -16px rgba(58,42,30,.16); }
  :global(.wl-link) { color: inherit; }
  :global(.wl-img) { aspect-ratio: 4/3; position: relative; overflow: hidden; background: var(--shop-bg-soft); }
  :global(.wl-body) { padding: 16px 18px 8px; display: flex; flex-direction: column; gap: 6px; }
  :global(.wl-meta) { font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--shop-ink-soft); font-weight: 600; }
  :global(.wl-body h3) {
    font-family: var(--shop-serif); font-weight: 400; font-size: 22px;
    line-height: 1.1; margin: 0;
  }
  :global(.wl-price) {
    font-family: var(--shop-serif); font-size: 18px; color: var(--shop-ink);
    margin-top: 4px;
  }
  :global(.wl-actions-row) {
    display: flex; justify-content: space-between; align-items: center; gap: 8px;
    padding: 8px 18px 18px;
  }
  :global(.wl-add) {
    flex: 1; padding: 10px 14px; border-radius: 999px;
    background: var(--shop-ink); color: var(--shop-bg);
    border: 0; cursor: pointer; font: 600 12px/1 var(--shop-sans);
    transition: background .2s;
  }
  :global(.wl-add:hover) { background: var(--shop-accent); }
  :global(.wl-remove) {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--shop-warm-soft); color: var(--shop-accent);
    border: 0; cursor: pointer; font-size: 16px;
    display: grid; place-items: center;
  }
  :global(.wl-remove:hover) { background: var(--shop-accent); color: white; }

  .wl-actions {
    margin-top: 32px; padding-top: 24px;
    border-top: 1px solid var(--shop-line);
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 12px;
  }
  .wl-actions-btns { display: flex; align-items: center; gap: 14px; }
  .wl-count { font-size: 13px; color: var(--shop-ink-soft); }
  .wl-clear {
    background: none; border: 0; cursor: pointer;
    color: var(--shop-ink-soft); font-size: 13px;
    text-decoration: underline; padding: 4px;
  }
  .wl-clear:hover { color: var(--shop-accent-deep); }

  @media (max-width: 980px) {
    .wl-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .wl-grid { grid-template-columns: 1fr; }
  }
</style>
