---
/**
 * Trang gallery phòng mẫu — /phong-mau/.
 * Layout: Hero (copy + ảnh isometric) → "Hình dung không gian sống" (ảnh bản vẽ
 * mặt bằng lớn) → lưới phòng mẫu → CTA. Data: phong-mau.yml.
 * Ảnh (hero iso + bản vẽ) upload qua admin; chưa có → fallback gradient/placeholder.
 */
import ShopLayout from '../../layouts/ShopLayout.astro';
import Nav from '../../components/shop/Nav.astro';
import Footer from '../../components/shop/Footer.astro';
import phongMau from '../../data/phong-mau.yml';
import { jsonLd } from '../../lib/jsonld';

const data = phongMau as any;
const hero = data.hero ?? {};
const fp = data.floorplan ?? {};
const intro = data.sections?.intro ?? {};
const rooms = (data.rooms ?? []) as any[];

const SITE_URL = 'https://www.wotu.vn';
const PAGE_URL = `${SITE_URL}/phong-mau/`;
const desc = 'Khám phá phòng mẫu WOTU — sơ đồ mặt bằng, phối cảnh 3D và chi tiết từng món nội thất. Phòng khách, phòng ngủ, bếp & phòng ăn được dựng sẵn để bạn lấy cảm hứng.';

const liveRooms = rooms.filter((r) => !r.soon && r.href);

// Thumb 640px (sinh bởi scripts/gen-upload-thumbs.mjs) cho ảnh /uploads/*.webp.
// srcset → màn nhỏ tải ~77KB thay bản full ~382KB. File thiếu → trình duyệt
// fallback về src (degrade an toàn).
const thumb640 = (p?: string) =>
  p && p.startsWith('/uploads/') && p.endsWith('.webp') ? p.replace(/\.webp$/, '-640.webp') : '';
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Trang chủ', item: SITE_URL + '/' },
    { '@type': 'ListItem', position: 2, name: 'Phòng mẫu', item: PAGE_URL },
  ],
};
const listSchema = liveRooms.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      itemListElement: liveRooms.map((r, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: `${r.name} ${r.nameEm ?? ''}`.trim(),
        url: SITE_URL + r.href,
      })),
    }
  : null;
---
<ShopLayout title="Phòng mẫu — Khám phá không gian WOTU" description={desc}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd(breadcrumbSchema)} />
    {listSchema && <script type="application/ld+json" set:html={jsonLd(listSchema)} />}
  </Fragment>
  <Nav active="Phòng mẫu" />

  <div class="container crumb">
    <a href="/">Trang chủ</a> / <span class="here">Phòng mẫu</span>
  </div>

  <main class="pm">
    {/* ===== HERO — cả cụm (chữ + ảnh) đổi theo từng phòng ===== */}
    <header class="pm-hero shop-reveal" data-pm-hero>
      <div class="container pm-hero-grid">
        {/* LEFT — copy đổi theo phòng (xếp chồng, đổi opacity) */}
        <div class="pm-hero-copy-stage">
          {rooms.map((r, i) => {
            const live = !r.soon && r.href;
            return (
              <div class={`pm-hero-copy${i === 0 ? ' active' : ''}`} data-copy={i} aria-hidden={i === 0 ? 'false' : 'true'}>
                <span class="pm-hero-eyebrow">{hero.eyebrow}</span>
                <h1 set:html={`${r.name} <em>${r.nameEm ?? ''}</em>`} />
                <p class="pm-hero-sub">{r.style} · {r.area}{r.soon ? ' · Sắp ra mắt' : ''}. {hero.sub}</p>
                <div class="pm-hero-actions">
                  {live
                    ? <a class="shop-btn shop-btn-primary" href={r.href}>Xem phòng này <span class="arr">→</span></a>
                    : <span class="shop-btn shop-btn-primary is-disabled" aria-disabled="true">Sắp ra mắt</span>}
                  {hero.cta2Label && <a class="shop-btn shop-btn-ghost" href={hero.cta2Href || '/#contact'}>{hero.cta2Label}</a>}
                </div>
              </div>
            );
          })}
        </div>

        {/* RIGHT — ảnh đổi theo phòng; mũi tên cố định trên viền box */}
        <div class="pm-hero-visual">
          {rooms.length > 1 && (
            <button class="pm-nav prev" type="button" aria-label="Phòng trước">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="m15 18-6-6 6-6"/></svg>
            </button>
          )}
          <div class="pm-imgwrap">
            {rooms.map((r, i) => {
              const imgSrc = r.photo || hero.image || '';
              return (
                <div class={`pm-img-slide${i === 0 ? ' active' : ''}`} data-img={i} aria-hidden={i === 0 ? 'false' : 'true'}>
                  {imgSrc
                    ? <img class="pm-slide-img" src={imgSrc} srcset={thumb640(imgSrc) ? `${thumb640(imgSrc)} 640w, ${imgSrc} 1600w` : undefined} sizes="(max-width: 1000px) 92vw, 45vw" alt={`${r.name} ${r.nameEm ?? ''}`.trim()} loading={i === 0 ? 'eager' : 'lazy'} fetchpriority={i === 0 ? 'high' : 'auto'} decoding="async" />
                    : <div class="pm-slide-ph"><span>{r.placeholder || hero.imageAlt || 'Phối cảnh phòng mẫu WOTU'}</span></div>
                  }
                </div>
              );
            })}
          </div>
          {rooms.length > 1 && (
            <button class="pm-nav next" type="button" aria-label="Phòng sau">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="m9 18 6-6-6-6"/></svg>
            </button>
          )}
          {rooms.length > 1 && (
            <div class="pm-dots">
              {rooms.map((_, i) => <button class="pm-dot" type="button" data-dot={i} aria-current={i === 0 ? 'true' : 'false'} aria-label={`Phòng ${i + 1}`}></button>)}
            </div>
          )}
          {rooms.length > 1 && (
            <button class="pm-pause" type="button" data-playing="true" aria-label="Tạm dừng chuyển ảnh tự động" hidden>
              <svg class="ic-pause" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><rect x="6" y="5" width="4" height="14" rx="1"/><rect x="14" y="5" width="4" height="14" rx="1"/></svg>
              <svg class="ic-play" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
            </button>
          )}
        </div>
      </div>
    </header>

    {/* ===== HÌNH DUNG KHÔNG GIAN SỐNG (sơ đồ mặt bằng) ===== */}
    <section class="pm-fp" id="so-do">
      <div class="container">
        <div class="pm-fp-head">
          {fp.eyebrow && <span class="eyebrow reveal" data-reveal style="--rev-delay: 0ms">{fp.eyebrow}</span>}
          <h2 class="reveal" data-reveal style="--rev-delay: 110ms" set:html={fp.heading ?? 'Hình dung <em>không gian sống</em>.'} />
          {fp.desc && <p class="pm-fp-desc reveal" data-reveal style="--rev-delay: 200ms">{fp.desc}</p>}
        </div>
        <figure class="pm-fp-card reveal-img" data-reveal data-parallax data-parallax-speed="-18">
          {fp.image
            ? <img src={fp.image} alt={fp.imageAlt || 'Bản vẽ mặt bằng — WOTU'} loading="lazy" decoding="async" />
            : <div class="pm-fp-empty"><span>Bản vẽ mặt bằng đang được cập nhật</span></div>
          }
          {fp.caption && <figcaption>{fp.caption}</figcaption>}
        </figure>
      </div>
    </section>

    {/* ===== LƯỚI PHÒNG MẪU ===== */}
    <section class="pm-rooms container" id="rooms">
      <div class="pm-rooms-head">
        {intro.eyebrow && <span class="eyebrow reveal" data-reveal style="--rev-delay: 0ms">{intro.eyebrow}</span>}
        {intro.heading && <h2 class="reveal" data-reveal style="--rev-delay: 110ms" set:html={intro.heading} />}
        {intro.desc && <p class="pm-rooms-desc reveal" data-reveal style="--rev-delay: 200ms">{intro.desc}</p>}
      </div>

      <div class="pm-gallery shop-reveal-stagger">
        {rooms.map((r) => {
          const fullName = `${r.name} ${r.nameEm ?? ''}`.trim();
          const Tag = (r.soon || !r.href) ? 'div' : 'a';
          return (
            <Tag class={`pm-card${r.tall ? ' tall' : ''}${r.soon ? ' soon' : ''}`} href={r.soon ? undefined : r.href} {...(r.soon ? {} : { 'data-tilt': true })}>
              <div class={`shop-ph ${r.tone ?? 'dark'}`}><span class="shop-ph-label">{r.placeholder}</span></div>
              {r.photo && <img class="shop-illo" src={r.photo} srcset={thumb640(r.photo) ? `${thumb640(r.photo)} 640w, ${r.photo} 1600w` : undefined} sizes="(max-width: 620px) 100vw, (max-width: 1000px) 50vw, 33vw" alt={fullName} loading="lazy" decoding="async" />}
              <div class="pm-card-top">
                <span class="pm-style">{r.style}</span>
                {r.soon && <span class="pm-soon">Sắp ra mắt</span>}
              </div>
              <div class="pm-card-foot">
                <div class="pm-card-name">
                  <span class="pm-name">{r.name} <em>{r.nameEm}</em></span>
                  <span class="pm-area">{r.area}</span>
                </div>
                {!r.soon && (
                  <span class="pm-arrow" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7M9 7h8v8"/></svg>
                  </span>
                )}
              </div>
            </Tag>
          );
        })}
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="container">
      <div class="pm-cta reveal" data-reveal>
        <div>
          <h2>Muốn một phòng <em>của riêng bạn</em>?</h2>
          <p>Gửi mặt bằng căn nhà — WOTU dựng phối cảnh 3D miễn phí và gợi ý combo phù hợp trong 24h.</p>
        </div>
        <a class="shop-btn shop-btn-primary" href="/#contact" data-magnetic>Đặt tư vấn 3D <span class="arr">→</span></a>
      </div>
    </section>
  </main>

  <Footer />
</ShopLayout>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const cms = window.location.search.includes('cms=1');

  // Lớp motion nâng cao (tilt/parallax/magnetic) — tải LƯỜI khi idle, gate reduce/cms.
  if (!reduce && !cms) {
    const load = () => import('../../lib/shop-motion');
    if ('requestIdleCallback' in window) {
      (window as any).requestIdleCallback(load, { timeout: 2000 });
    } else {
      setTimeout(load, 200);
    }
  }

  // Hero carousel — đổi CẢ CỤM (chữ trái + ảnh phải) theo từng phòng.
  // Nâng cấp: cross-fade có CHIỀU + Ken Burns (CSS) + chữ rise + auto-play + swipe.
  const heroEl = document.querySelector<HTMLElement>('[data-pm-hero]');
  if (heroEl) {
    const copies = Array.from(heroEl.querySelectorAll<HTMLElement>('.pm-hero-copy'));
    const imgs = Array.from(heroEl.querySelectorAll<HTMLElement>('.pm-img-slide'));
    const dots = Array.from(heroEl.querySelectorAll<HTMLElement>('.pm-dot'));
    const prev = heroEl.querySelector<HTMLElement>('.pm-nav.prev');
    const next = heroEl.querySelector<HTMLElement>('.pm-nav.next');
    const visual = heroEl.querySelector<HTMLElement>('.pm-hero-visual');
    const pauseBtn = heroEl.querySelector<HTMLElement>('.pm-pause');
    const n = Math.max(copies.length, imgs.length);
    let i = 0;
    let timer: ReturnType<typeof setInterval> | null = null;
    let paused = false; // user chủ động dừng (WCAG 2.2.2) — không tự chạy lại

    function show(k: number, dir = 1) {
      i = (k + n) % n;
      copies.forEach((c, j) => { c.classList.toggle('active', j === i); c.setAttribute('aria-hidden', j === i ? 'false' : 'true'); });
      imgs.forEach((m, j) => {
        const on = j === i;
        m.classList.toggle('active', on);
        m.setAttribute('aria-hidden', on ? 'false' : 'true');
        if (on && !reduce) {
          // Slide-in có chiều: đặt lệch rồi clear → transition kéo về 0 (chỉ transform/opacity).
          m.style.transform = `translateX(${dir * 16}px)`;
          void m.offsetWidth; // force reflow để transition chạy
          m.style.transform = '';
        }
      });
      dots.forEach((d, j) => d.setAttribute('aria-current', j === i ? 'true' : 'false'));
    }

    function startAuto() {
      if (reduce || n < 2 || paused) return;
      stopAuto();
      timer = setInterval(() => show(i + 1, 1), 5000);
    }
    function stopAuto() { if (timer) { clearInterval(timer); timer = null; } }
    // Thao tác thủ công → đổi slide + reset đồng hồ auto-play.
    function go(k: number, dir: number) { show(k, dir); startAuto(); }

    // Nút Tạm dừng/Tiếp tục (WCAG 2.2.2) — chỉ ý nghĩa khi có auto-play.
    if (pauseBtn && !reduce && n > 1) {
      pauseBtn.hidden = false;
      pauseBtn.addEventListener('click', () => {
        paused = !paused;
        pauseBtn.setAttribute('data-playing', paused ? 'false' : 'true');
        pauseBtn.setAttribute('aria-label', paused ? 'Tiếp tục chuyển ảnh tự động' : 'Tạm dừng chuyển ảnh tự động');
        if (paused) stopAuto(); else startAuto();
      });
    }

    prev?.addEventListener('click', () => go(i - 1, -1));
    next?.addEventListener('click', () => go(i + 1, 1));
    dots.forEach((d, j) => d.addEventListener('click', () => go(j, j > i ? 1 : -1)));

    // Tạm dừng khi hover / focus trong cụm hero.
    heroEl.addEventListener('pointerenter', stopAuto);
    heroEl.addEventListener('pointerleave', startAuto);
    heroEl.addEventListener('focusin', stopAuto);
    heroEl.addEventListener('focusout', startAuto);

    // Vuốt trên ảnh (mobile) đổi phòng.
    if (visual) {
      let sx = 0, sw = false;
      visual.addEventListener('pointerdown', (e) => { sx = e.clientX; sw = true; });
      visual.addEventListener('pointerup', (e) => {
        if (!sw) return; sw = false;
        const dx = e.clientX - sx;
        if (Math.abs(dx) > 40) go(dx < 0 ? i + 1 : i - 1, dx < 0 ? 1 : -1);
      });
      visual.addEventListener('pointercancel', () => { sw = false; });
    }

    show(0);
    startAuto();
  }
</script>

<style>
  .crumb { padding: 22px 0 6px; font-size: 13px; color: var(--shop-ink-soft); }
  .crumb a { color: var(--shop-ink-soft); text-decoration: none; }
  .crumb a:hover { color: var(--shop-accent); }
  .crumb .here { color: var(--shop-ink); }

  .pm { padding: 0 0 90px; }
  .eyebrow { font-size: 12px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--shop-ink-soft); font-weight: 600; display: inline-flex; align-items: center; gap: 10px; }
  .eyebrow::before { content: ""; width: 22px; height: 1px; background: currentColor; opacity: .6; }

  /* ── HERO ── */
  .pm-hero { background: var(--shop-bg-soft); padding: 56px 0 64px; margin-bottom: 8px; }
  .pm-hero-grid { display: grid; grid-template-columns: 1.05fr 1fr; gap: 56px; align-items: center; }
  .pm-hero-eyebrow { display: inline-block; font-size: 12px; letter-spacing: .16em; text-transform: uppercase; color: var(--shop-accent-deep); font-weight: 700; }
  .pm-hero-sub { font-size: 16px; line-height: 1.7; color: var(--shop-ink-soft); margin: 18px 0 0; max-width: 520px; }
  .pm-hero-actions { display: flex; flex-wrap: wrap; gap: 12px; margin: 28px 0 0; }
  .shop-btn.is-disabled { opacity: .5; pointer-events: none; cursor: default; }

  /* ── Hero: cụm carousel (chữ trái + ảnh phải đổi cùng lúc) ── */
  /* LEFT: các bản copy xếp chồng cùng ô grid, đổi opacity */
  .pm-hero-copy-stage { display: grid; }
  .pm-hero-copy { grid-area: 1 / 1; opacity: 0; pointer-events: none; transition: opacity .4s ease; }
  .pm-hero-copy.active { opacity: 1; pointer-events: auto; }
  /* Chữ rise theo dòng mỗi lần phòng được kích hoạt. */
  .pm-hero-copy.active .pm-hero-eyebrow,
  .pm-hero-copy.active h1,
  .pm-hero-copy.active .pm-hero-sub,
  .pm-hero-copy.active .pm-hero-actions { animation: pm-copy-rise .6s cubic-bezier(0.22,0.61,0.36,1) both; }
  .pm-hero-copy.active h1 { animation-delay: .05s; }
  .pm-hero-copy.active .pm-hero-sub { animation-delay: .12s; }
  .pm-hero-copy.active .pm-hero-actions { animation-delay: .18s; }
  @keyframes pm-copy-rise { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }
  .pm-hero-copy h1 { font-family: var(--shop-serif); font-weight: 400; font-size: clamp(34px, 5.2vw, 60px); line-height: 1.02; margin: 14px 0 0; }
  .pm-hero-copy h1 em { font-style: italic; color: var(--shop-accent); }

  /* RIGHT: box ảnh + slide xếp chồng */
  .pm-hero-visual { position: relative; aspect-ratio: 1/1; }
  .pm-imgwrap {
    position: absolute; inset: 0; border-radius: var(--shop-radius-lg); overflow: hidden;
    background: transparent;
  }
  .pm-img-slide { position: absolute; inset: 0; opacity: 0; transition: opacity .5s ease, transform .5s cubic-bezier(0.22,0.61,0.36,1); }
  .pm-img-slide.active { opacity: 1; }
  .pm-slide-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: contain; }
  /* Ken Burns — ảnh active phóng chậm trong lúc hiển thị, replay mỗi lần đổi phòng. */
  .pm-img-slide.active .pm-slide-img { animation: pm-ken 7s ease-out forwards; }
  @keyframes pm-ken { from { transform: scale(1.001); } to { transform: scale(1.06); } }
  .pm-slide-ph {
    position: absolute; inset: 0; display: grid; place-items: center; text-align: center; padding: 16px;
    background: repeating-linear-gradient(135deg, #D9CDB6 0 18px, #C9B89C 18px 36px);
  }
  .pm-slide-ph span {
    font-family: var(--shop-sans); font-size: 11px; letter-spacing: .18em; text-transform: uppercase;
    color: var(--shop-ink-soft); text-shadow: 0 1px 2px rgba(255,255,255,.3);
  }

  /* Mũi tên nằm ngay trên viền 2 bên box (tâm nút trùng đường viền) */
  .pm-nav {
    position: absolute; top: 50%; z-index: 4;
    width: 42px; height: 42px; border-radius: 50%;
    background: var(--shop-bg-card); color: var(--shop-ink);
    border: 1px solid var(--shop-line); cursor: pointer;
    display: grid; place-items: center;
    box-shadow: 0 8px 22px -8px rgba(42, 37, 32, .45);
    transition: background .2s, color .2s;
  }
  .pm-nav:hover { background: var(--shop-ink); color: var(--shop-bg); }
  .pm-nav.prev { left: 0; transform: translate(-50%, -50%); }
  .pm-nav.next { right: 0; transform: translate(50%, -50%); }
  .pm-dots { position: absolute; left: 50%; bottom: 12px; transform: translateX(-50%); z-index: 4; display: flex; gap: 7px; }
  .pm-dot {
    width: 8px; height: 8px; border-radius: 50%; padding: 0; cursor: pointer;
    background: rgba(255,255,255,.55); border: none; transition: background .2s, transform .2s;
  }
  .pm-dot[aria-current="true"] { background: var(--shop-bg); transform: scale(1.25); }
  /* Nút Tạm dừng/Tiếp tục auto-play (WCAG 2.2.2) — góc dưới-trái box ảnh. */
  .pm-pause {
    position: absolute; left: 12px; bottom: 8px; z-index: 4;
    width: 28px; height: 28px; border-radius: 50%; padding: 0;
    display: grid; place-items: center; cursor: pointer;
    background: rgba(0,0,0,.42); color: #fff; border: none;
    backdrop-filter: blur(6px); transition: background .2s;
  }
  .pm-pause:hover { background: rgba(0,0,0,.62); }
  .pm-pause .ic-play { display: none; }
  .pm-pause[data-playing="false"] .ic-pause { display: none; }
  .pm-pause[data-playing="false"] .ic-play { display: block; }

  /* ── HÌNH DUNG KHÔNG GIAN SỐNG ── */
  .pm-fp { padding: 70px 0 64px; }
  .pm-fp-head { text-align: center; max-width: 720px; margin: 0 auto 40px; }
  .pm-fp-head h2 { font-family: var(--shop-serif); font-weight: 400; font-size: clamp(30px, 4.4vw, 50px); line-height: 1.04; margin: 14px 0 0; }
  .pm-fp-head h2 :global(em) { font-style: italic; color: var(--shop-accent); }
  .pm-fp-desc { font-size: 15px; line-height: 1.7; color: var(--shop-ink-soft); margin: 18px auto 0; max-width: 600px; }
  .pm-fp-card {
    background: var(--shop-bg-card); border: 1px solid var(--shop-line);
    border-radius: var(--shop-radius-lg); padding: 22px; margin: 0;
    box-shadow: 0 18px 50px -32px rgba(42, 37, 32, .4);
  }
  .pm-fp-card img { display: block; width: 100%; height: auto; border-radius: var(--shop-radius); }
  .pm-fp-empty {
    display: grid; place-items: center; aspect-ratio: 16/10;
    border: 1px dashed var(--shop-line); border-radius: var(--shop-radius);
    background: repeating-linear-gradient(135deg, var(--shop-bg-soft) 0 16px, var(--shop-bg) 16px 32px);
    color: var(--shop-ink-soft); font-size: 14px; font-style: italic;
  }
  .pm-fp-card figcaption { margin-top: 14px; text-align: center; font-size: 13px; color: var(--shop-ink-soft); font-style: italic; }

  /* ── LƯỚI PHÒNG ── */
  .pm-rooms { padding-top: 8px; scroll-margin-top: 80px; }
  .pm-rooms-head { max-width: 640px; margin-bottom: 32px; }
  .pm-rooms-head h2 { font-family: var(--shop-serif); font-weight: 400; font-size: clamp(28px, 4vw, 44px); line-height: 1.04; margin: 12px 0 0; }
  .pm-rooms-head h2 :global(em) { font-style: italic; color: var(--shop-accent); }
