---
/**
 * Trang chi tiết combo — route động sinh từ shop-home.yml (1 template cho cả 6 combo).
 * Shell gọn theo kiểu An Cư; các section giàu (combo gồm grid, mô tả, thông số,
 * sơ đồ kích thước, đánh giá, FAQ) chỉ render khi combo có "detail" data (hiện chỉ Tổ Ấm).
 * Chỉ dùng data có thật — combo chưa có detail thì các section đó tự ẩn.
 */
import ShopLayout from '../../layouts/ShopLayout.astro';
import Nav from '../../components/shop/Nav.astro';
import Footer from '../../components/shop/Footer.astro';
import SplitWords from '../../components/SplitWords.astro';
import shopHome from '../../data/shop-home.yml';
import toAmDetail from '../../data/combo-to-am.yml';
import { jsonLd } from '../../lib/jsonld';

const data = shopHome as any;
const combos = (data.combos ?? []) as any[];

// Map slug → file detail giàu (optional). Combo muốn giàu thì thêm 1 import + 1 dòng.
const DETAIL: Record<string, any> = { 'to-am': toAmDetail };

export function getStaticPaths() {
  const d = shopHome as any;
  return (d.combos ?? [])
    .map((c: any) => ({ params: { slug: String(c.id).replace(/^combo-/, '') }, props: { c } }));
}

interface Props { c: any; }
const { c } = Astro.props;
const slug = String(c.id).replace(/^combo-/, '');
const fullName = `${c.name} ${c.nameEm ?? ''}${c.nameTail ?? ''}`.trim();
const hasPhoto = !!c.photo;
const illo = c.photo || `/uploads/products/combo-${c.room}.png`;

// "Combo gồm": tách desc theo " · " nếu là danh sách; ngược lại dùng làm prose.
const parts = String(c.desc ?? '').split(' · ').map((s) => s.trim()).filter(Boolean);
const isList = parts.length > 1;

const num = (s: string) => Number(String(s ?? '').replace(/[^\d]/g, '')) || 0;
const oldNum = num(c.priceOld);
const discount = oldNum && c.price ? Math.round((1 - c.price / oldNum) * 100) : 0;

const roomLabel: Record<string, string> = { studio: 'căn hộ', 'phong-khach': 'phòng khách', 'phong-ngu': 'phòng ngủ', 'phong-an': 'phòng ăn', 'lam-viec': 'phòng làm việc', 'tre-em': 'phòng trẻ em' };
const related = combos.filter((x) => x.id !== c.id).slice(0, 3);

// Bảng giá đồ rời — chỉ render khi combo có items (dữ liệu thật do user nhập qua admin).
const items = ((c.items ?? []) as any[]).filter((it) => it?.name);
const itemsTotal = items.reduce((s, it) => s + (Number(it.price) || 0), 0);
const fmtVND = (n: number) => (Number(n) > 0 ? Number(n).toLocaleString('vi-VN') + 'đ' : 'Liên hệ');

// ── Detail giàu (optional) ──────────────────────────────────────────────────
const detail = DETAIL[slug] ?? null;
const richItems = (detail?.items ?? []) as any[];
const descBlocks = (detail?.descBlocks ?? []) as any[];
const specs = (detail?.specs ?? []) as any[];
const dim = detail?.dimensions ?? null;
const dReviews = detail?.reviews ?? null;
const dFaq = (detail?.faq ?? []) as any[];

const readNav: { id: string; label: string }[] = [];
if (richItems.length) readNav.push({ id: 'items', label: 'Combo gồm' });
if (descBlocks.length) readNav.push({ id: 'desc', label: 'Mô tả' });
if (specs.length) readNav.push({ id: 'specs', label: 'Thông số' });
if (dim) readNav.push({ id: 'dim', label: 'Kích thước' });
if (dReviews) readNav.push({ id: 'reviews', label: `Đánh giá · ${dReviews.total}` });
if (dFaq.length) readNav.push({ id: 'faq', label: 'Câu hỏi' });
const hasRich = readNav.length > 0;

const SITE_URL = 'https://www.wotu.vn';
const PAGE_URL = `${SITE_URL}/combo/${slug}/`;
const desc = `${fullName} — ${c.cat}. ${c.desc ?? ''} Trọn gói thiết kế, sản xuất tại xưởng WOTU Quy Nhơn và lắp đặt tận nơi. Bảo hành 5 năm.`;

// Strip HTML cho FAQ schema (Google không nhận HTML trong answer)
function stripHtml(html: string) {
  return String(html ?? '').replace(/<[^>]+>/g, '');
}

const productSchema: any = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: fullName,
  description: desc,
  category: `Combo ${roomLabel[c.room] ?? 'nội thất'}`,
  brand: { '@type': 'Brand', name: 'WOTU' },
  sku: c.id,
  url: PAGE_URL,
  offers: {
    '@type': 'Offer',
    price: c.price,
    priceCurrency: 'VND',
    availability: 'https://schema.org/InStock',
    url: PAGE_URL,
    seller: { '@type': 'Organization', name: 'WOTU' },
  },
};
if (dReviews) {
  productSchema.aggregateRating = {
    '@type': 'AggregateRating',
    ratingValue: dReviews.score,
    reviewCount: dReviews.total,
    bestRating: '5',
    worstRating: '1',
  };
}
const faqSchema = dFaq.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: dFaq.map((f: any) => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: stripHtml(f.answer) },
      })),
    }
  : null;
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Trang chủ', item: SITE_URL + '/' },
    { '@type': 'ListItem', position: 2, name: 'Combo nội thất', item: SITE_URL + '/#combos' },
    { '@type': 'ListItem', position: 3, name: fullName, item: PAGE_URL },
  ],
};
---
<ShopLayout title={`${fullName} — Combo ${roomLabel[c.room] ?? 'nội thất'} — WOTU`} description={desc} ogType="product">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd(productSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={jsonLd(faqSchema)} />}
    <script type="application/ld+json" set:html={jsonLd(breadcrumbSchema)} />
  </Fragment>
  <Nav active="Combo nội thất" />

  <div class="container crumb">
    <a href="/">Trang chủ</a> / <a href="/#combos">Combo nội thất</a> / <span class="here">{fullName}</span>
  </div>

  <main class="pd container">
    <section class="pd-top">
      <div class="pd-gallery">
        <div class="pd-main">
          <div class={`shop-ph ${c.tone ?? ''}`}><span class="shop-ph-label">{c.placeholder ?? fullName}</span></div>
          <img class="shop-illo" src={illo} alt={`${hasPhoto ? '' : 'Minh hoạ '}${fullName} — WOTU`} loading="eager" fetchpriority="high" decoding="async" />
          {c.badge && <div class="pd-badges"><span class={`b-tag${c.badgeClass ? ' ' + c.badgeClass : ' dark'}`}>{c.badge}</span></div>}
        </div>
        {!hasPhoto && <p class="pd-illo-note">Ảnh minh hoạ — ảnh chụp thật đang được cập nhật.</p>}
      </div>

      <div class="pd-info">
        <span class="pd-cat reveal" data-reveal style="--rev-delay: 0ms">{c.cat}</span>
        <SplitWords tag="h1" text={`${c.name} <em>${c.nameEm}</em>${c.nameTail ?? ''}`} base={80} step={45} />


        <div class="pd-price">
          {c.priceOld && <s>{c.priceOld}</s>}
          <strong>{c.priceNew}</strong>
          {discount > 0 && <span class="pd-off">−{discount}%</span>}
        </div>
        {c.priceNote && <div class="pd-note">{c.priceNote.replace(/^·\s*/, '')}</div>}

        {isList ? (
          <div class="pd-block">
            <span class="pd-label">Combo gồm</span>
            <ul class="pd-includes">{parts.map((it) => <li>{it}</li>)}</ul>
          </div>
        ) : (
          <p class="pd-lead">{c.desc}</p>
        )}

        <div class="pd-actions">
          <button class="shop-btn shop-btn-primary" type="button" id="pdAdd"
            data-id={c.id} data-name={`Combo ${c.nameEm}`} data-price={c.price}>
            + Thêm combo vào giỏ
          </button>
          <button class="shop-btn shop-btn-outline" type="button" id="pdFav" data-fav={c.id} aria-label="Yêu thích">♡ Lưu</button>
        </div>
        <a class="pd-zalo" href="https://zalo.me/0933774708" target="_blank" rel="noopener noreferrer">Cần tư vấn combo? Chat Zalo 0933 774 708 →</a>

        <ul class="pd-trust">
          <li>Trọn gói thiết kế + thi công</li>
          <li>Bảo hành 5 năm</li>
          <li>Giao &amp; lắp tận nơi</li>
        </ul>
        <a class="pd-room-link" href={`/san-pham/?room=${c.room}`}>Xem sản phẩm lẻ cho {roomLabel[c.room] ?? 'không gian này'} →</a>
      </div>
    </section>

    {/* ===== READING NAV (chỉ khi có section giàu) ===== */}
    {hasRich && (
      <nav class="read-nav">
        <ul>
          {readNav.map((s, i) => <li><a href={`#${s.id}`} class={i === 0 ? 'active' : ''}>{s.label}</a></li>)}
        </ul>
      </nav>
    )}

    {/* ===== COMBO GỒM (grid + bundle) ===== */}
    {richItems.length > 0 && (
      <section class="block" id="items">
        <div class="block-head">
          <div>
            <span class="eyebrow">Combo gồm {richItems.length} món</span>
            <h2>Mua trọn bộ — <em>tiết kiệm {detail.bundleSaveLabel}</em>.</h2>
          </div>
          <div class="right">Mỗi món đều có thể mua lẻ, nhưng combo đồng bộ chất liệu &amp; tỉ lệ — được KTS Wotu tinh chỉnh.</div>
        </div>

        <div class="items-grid">
          {richItems.map((item: any) => {
            const Tag = item.href ? 'a' : 'article';
            return (
              <Tag class="item-card" href={item.href || undefined} style={item.href ? 'text-decoration: none;' : undefined}>
                <div class="item-img">
                  <div class={`shop-ph${item.tone ? ' ' + item.tone : ''}`}><span class="shop-ph-label">{item.placeholder}</span></div>
                  <span class="item-no">{item.no}</span>
                </div>
                <div class="item-body">
                  <div class="item-meta">{item.meta}</div>
                  <h4>{item.name}</h4>
                  <div class="item-row">
                    <span style="color: var(--shop-ink-soft); text-decoration: line-through;">{item.priceOld}</span>
                    <span class="qty-tag">×1</span>
                  </div>
                </div>
              </Tag>
            );
          })}
        </div>

        {detail.bundleTotalLabel && (
          <div class="bundle-total">
            <div>
              <div class="bt-eyebrow">Tổng giá mua lẻ</div>
              <div class="bt-strike">{detail.bundleTotalLabel}</div>
            </div>
            <div class="bt-arrow"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--shop-accent)" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7" /></svg></div>
            <div>
              <div class="bt-eyebrow combo">Giá combo</div>
              <div class="bt-now">{detail.bundlePriceLabel}</div>
            </div>
            <div class="bt-arrow"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7" /></svg></div>
            <div>
              <div class="bt-eyebrow save">Tiết kiệm</div>
              <div class="bt-save">{detail.bundleSaveLabel}</div>
            </div>
          </div>
        )}
      </section>
    )}

    {/* ===== MÔ TẢ CHI TIẾT (descBlocks) ===== */}
    {descBlocks.length > 0 && (
      <section class="block" id="desc">
        {descBlocks[0].headingHtml && (
          <div class="block-head">
            <div>
              <span class="eyebrow reveal" data-reveal style="--rev-delay: 0ms">{descBlocks[0].eyebrowSection}</span>
              <h2 class="reveal" data-reveal style="--rev-delay: 120ms" set:html={descBlocks[0].headingHtml} />
            </div>
            <div class="right reveal" data-reveal style="--rev-delay: 180ms">{descBlocks[0].headingRight}</div>
          </div>
        )}
        {descBlocks.map((b: any) => (
          <div class={`desc-grid${b.flip ? ' flip' : ''}`}>
            <div class="desc-img reveal-img" data-reveal><div class={`shop-ph${b.imgTone ? ' ' + b.imgTone : ''}`}><span class="shop-ph-label">{b.imgLabel}</span></div></div>
            <div class="desc-body">
              <span class="eyebrow">{b.eyebrow}</span>
              <h3>{b.h3}</h3>
              <p set:html={b.body} />
              {b.list && (
                <ul class="desc-list">
                  {(b.list as any[]).map((li: string) => (
                    <li><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12" /></svg>{li}</li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        ))}
      </section>
    )}

    {/* ===== THÔNG SỐ ===== */}
    {specs.length > 0 && (
      <section class="block" id="specs">
        <div class="block-head">
          <div>
            <span class="eyebrow">Thông số kỹ thuật</span>
            <h2>Bóc tách <em>từng centimet</em>.</h2>
          </div>
          <div class="right">Tất cả số đo, chất liệu và chứng nhận đều minh bạch — bạn không phải đoán.</div>
        </div>
        <div class="specs-grid">
          {specs.map((sp: any) => (
            <div>
              <h4 class="spec-title">{sp.title}</h4>
              {(sp.rows as any[]).map((r: any) => (
                <div class="spec-row"><span class="k">{r.k}</span><span class="v">{r.v}</span></div>
              ))}
            </div>
          ))}
        </div>
      </section>
    )}

    {/* ===== SƠ ĐỒ KÍCH THƯỚC ===== */}
    {dim && (
      <section class="block" id="dim">
        <div class="block-head">
          <div>
            <span class="eyebrow reveal" data-reveal style="--rev-delay: 0ms">Sơ đồ &amp; kích thước</span>
            <h2 class="reveal" data-reveal style="--rev-delay: 120ms" set:html={dim.headingHtml} />
          </div>
          <div class="right reveal" data-reveal style="--rev-delay: 180ms">{dim.caption}</div>
        </div>
        <div class="dim-wrap">
          <div class="dim-grid">
            <Fragment set:html={dim.svg} />
            <div class="dim-legend">
              {(dim.legend as any[]).map((lg: any) => (
                <div class="legend-item">
                  {lg.kind === 'line' ? (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--shop-ink)" stroke-width="1.5"><path d="M3 12h18" /></svg>
                  ) : (
                    <span class={`legend-dot lg-${lg.kind}`}></span>
                  )}
                  <div><b>{lg.title}</b><br /><span style="color: var(--shop-ink-soft); font-size: 12px;">{lg.sub}</span></div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    {/* ===== ĐÁNH GIÁ ===== */}
    {dReviews && (
      <section class="block" id="reviews">
        <div class="block-head">
          <div>
            <span class="eyebrow">Đánh giá khách hàng</span>
            <h2><em>{dReviews.score} / 5</em> · {dReviews.total} đánh giá thật.</h2>
          </div>
          <div class="right">Tổng hợp đánh giá xác thực từ khách đã mua.</div>
        </div>
        <div class="rev-grid">
          <aside class="rev-summary">
            <div class="rev-score">{dReviews.score}<sub>/5</sub></div>
            <div class="stars" style="font-size: 22px; margin-top: 4px;">★★★★★</div>
            <div style="font-size: 13px; color: var(--shop-ink-soft); margin-top: 4px;">trên {dReviews.total} đánh giá xác thực</div>
            <div class="rev-bars">
              {(dReviews.distribution as any[]).map((row: any) => (
                <div class="rev-bar">
                  <span>{row.stars}★</span>
                  <div class="bar-track"><div class="bar-fill" style={`width: ${row.pct}%;`}></div></div>
                  <span style="text-align:right;">{row.count}</span>
                </div>
              ))}
            </div>
          </aside>
          <div class="review-list">
            {(dReviews.items as any[]).map((r: any) => (
              <article class="review-item">
                <div class="review-head">
                  <div class="review-author">
                    <div class="avatar">{r.initial}</div>
                    <div>
                      <div class="name">{r.name}</div>
                      <div class="when">{r.when}</div>
                    </div>
                  </div>
                  <span class="stars">★★★★★</span>
                </div>
                <div class="review-body">{r.body}</div>
                <div class="review-meta">
                  <span>Tông màu: <b style="color: var(--shop-ink);">{r.color}</b></span>
                  <span>Kích thước: <b style="color: var(--shop-ink);">{r.size}</b></span>
                  <span>👍 Có ích · {r.helpful}</span>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* ===== VỀ COMBO NÀY (combo gọn không có descBlocks) ===== */}
    {descBlocks.length === 0 && (
      <section class="pd-desc">
        <h2>Về combo này</h2>
        <p>{desc}</p>
        <p>Mua trọn combo giúp đồng bộ tông màu và vật liệu, tiết kiệm hơn so với mua lẻ từng món. Đội WOTU khảo sát không gian thực tế trước khi chốt phương án để mọi thứ vừa vặn căn nhà của bạn.</p>
      </section>
    )}

    {/* ===== BẢNG GIÁ ĐỒ RỜI (combo có c.items) ===== */}
    {items.length > 0 && (
      <section class="pd-quote">
        <div class="pq-head"><span class="pq-rule"></span><h2>Bảng giá đồ rời</h2><span class="pq-rule"></span></div>
        <p class="pd-quote-sub">{c.name} <em>{c.nameEm}</em>{c.nameTail} · {c.cat}</p>

        <div class="pq-grid">
          {items.map((it, i) => (
            <article class="pq-card">
              <div class="pq-img">
                <div class={`shop-ph ${c.tone ?? ''}`}><span class="shop-ph-label">{it.name}</span></div>
                {it.photo && <img class="shop-illo" src={it.photo} alt={`${it.name} — ${fullName}`} loading="lazy" decoding="async" />}
              </div>
              <div class="pq-body">
                <h4><span class="pq-no">{String(i + 1).padStart(2, '0')}.</span> {it.name}</h4>
                {it.dim && <div class="pq-dim">KT: {it.dim}</div>}
                <div class="pq-price">{fmtVND(it.price)}</div>
              </div>
            </article>
          ))}
        </div>

        <div class="pq-footer">
          <div class="pq-total">
            <span class="pq-total-label">Tổng giá trị đồ rời</span>
            <span class="pq-total-val">{fmtVND(itemsTotal)}</span>
            <div class="pq-total-fine">
              <span>* Giá đã bao gồm VAT</span>
              <span>* Chưa bao gồm phí vận chuyển và lắp đặt</span>
            </div>
          </div>
          <div class="pq-ghichu">
            <span class="pq-ghichu-label">Ghi chú</span>
            <ul class="pq-notes">
              <li>Báo giá có hiệu lực trong 15 ngày kể từ ngày báo giá.</li>
              <li>Sản phẩm có thể thay đổi màu sắc tùy theo thực tế.</li>
              <li>Liên hệ để được tư vấn chi tiết và ưu đãi tốt nhất.</li>
            </ul>
          </div>
        </div>
      </section>
    )}

    {/* ===== FAQ ===== */}
    {dFaq.length > 0 && (
      <section class="block" id="faq">
        <div class="block-head">
          <div>
            <span class="eyebrow">Câu hỏi thường gặp</span>
            <h2>Trước khi mua, <em>bạn thường hỏi</em>.</h2>
          </div>
          <div class="right">Không thấy câu trả lời bạn cần? Gọi 0933 774 708 hoặc chat Zalo — KTS trực 8h–21h.</div>
        </div>
        <div class="faq">
          {dFaq.map((f: any) => (
            <details open={f.open || undefined}>
              <summary>{f.question}</summary>
              <div class="ans" set:html={f.answer} />
            </details>
          ))}
        </div>
      </section>
    )}

    {/* ===== RELATED ===== */}
    {related.length > 0 && (
      <section class="pd-related">
        <h2>Combo khác</h2>
        <div class="pd-rel-grid">
          {related.map((r: any) => (
            <a class="pd-rel-card" href={r.id === 'combo-to-am' ? '/combo/to-am/' : `/combo/${String(r.id).replace(/^combo-/, '')}/`}>
              <div class="pd-rel-img">
                <div class={`shop-ph ${r.tone ?? ''}`}></div>
                <img class="shop-illo" src={r.photo || `/uploads/products/combo-${r.room}.png`} alt={`${r.photo ? '' : 'Minh hoạ '}Combo ${r.nameEm}`} loading="lazy" decoding="async" />
              </div>
              <div class="pd-rel-body">
                <span>{r.cat}</span>
                <h3>{r.name} <em>{r.nameEm}</em>{r.nameTail}</h3>
                <div class="pd-rel-price">{r.priceNew}</div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>

  <Footer />

  {/* ===== STICKY CART BAR (chỉ combo giàu) ===== */}
  {hasRich && (
    <div class="sticky-bar" id="stickyBar">
      <span class="sb-title">{fullName}</span>
      <span class="sb-price">{c.priceOld && <s>{c.priceOld}</s>}{c.priceNew}</span>
      <button class="shop-btn shop-btn-primary" type="button" id="pdAddSticky"
        data-id={c.id} data-name={`Combo ${c.nameEm}`} data-price={c.price}>Thêm giỏ →</button>
    </div>
  )}
</ShopLayout>

<script>
  import { addToCart, toggleFavorite, isFavorite, toast } from '../../lib/shop-store';

  function wireAdd(el: HTMLElement | null) {
    el?.addEventListener('click', () => {
      addToCart({
        id: el.dataset.id ?? '',
        name: el.dataset.name ?? 'Combo',
        price: Number(el.dataset.price ?? 0),
      });
      toast(`✓ Đã thêm "${el.dataset.name}" vào giỏ`);
      (window as any).__wotuOpenCart?.();
    });
  }
  wireAdd(document.getElementById('pdAdd'));
  wireAdd(document.getElementById('pdAddSticky'));

  const fav = document.getElementById('pdFav');
  function syncFav() {
    if (!fav) return;
    const on = isFavorite(fav.dataset.fav ?? '');
    fav.dataset.active = on ? 'true' : 'false';
    fav.textContent = on ? '♥ Đã lưu' : '♡ Lưu';
  }
  fav?.addEventListener('click', () => { toggleFavorite(fav.dataset.fav ?? ''); syncFav(); });
  syncFav();

  // ===== Reading nav active + sticky bar (chỉ khi có markup) =====
  const readLinks = Array.from(document.querySelectorAll('.read-nav a'));
  const stickyBar = document.getElementById('stickyBar');
  const hero = document.querySelector('.pd-top');
  if (readLinks.length || stickyBar) {
    const sections = readLinks
      .map((a) => document.getElementById((a.getAttribute('href') ?? '').slice(1)))
      .filter((el): el is HTMLElement => el !== null);

    function onScroll() {
      const y = window.scrollY + 200;
      let active = sections[0];
      for (const s of sections) if (s.offsetTop <= y) active = s;
      if (active) readLinks.forEach((a) => a.classList.toggle('active', a.getAttribute('href') === '#' + active!.id));
      if (hero && stickyBar) {
        const r = hero.getBoundingClientRect();
        stickyBar.classList.toggle('in', r.bottom < 100);
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    readLinks.forEach((a) => {
      a.addEventListener('click', (e) => {
        const id = a.getAttribute('href');
        if (id && id.startsWith('#')) {
          const el = document.querySelector(id);
          if (el) {
            e.preventDefault();
            window.scrollTo({ top: (el as HTMLElement).offsetTop - 140, behavior: 'smooth' });
          }
        }
      });
    });
  }
</script>

