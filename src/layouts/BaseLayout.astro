---
import '../styles/global.css';
import site from '../data/site.yml';
import { img } from '../lib/unsplash';
import StructuredData from '../components/StructuredData.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  /** Schema.org type — defaults to website. Use 'article' for blog, 'project' for case study. */
  schemaType?: 'website' | 'article' | 'project';
  schemaDate?: string;
}

const {
  title = `WOTU — ${site.tagline}`,
  description = site.description,
  // Default OG: hero photo cropped to 1200×630 from Unsplash CDN — no extra
  // asset to host, no extra build time.
  ogImage = img('1768836180164-070b4c1a8f94', 1200, '16/9'),
  schemaType = 'website',
  schemaDate,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;

// Cloudflare Web Analytics — only inject if token is configured.
const cfToken = (site.analytics?.cfBeaconToken ?? '').trim();
const cfBeaconConfig = cfToken ? JSON.stringify({ token: cfToken }) : '';
---
<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https://images.unsplash.com https://avatars.githubusercontent.com; connect-src 'self' https://api.web3forms.com https://api.github.com https://github.com https://unpkg.com https://cloudflareinsights.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self' https://github.com https://api.web3forms.com;" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="vi_VN" />
    <meta property="og:site_name" content="WOTU" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data: LocalBusiness + WebSite + page-specific schema -->
    <StructuredData
      type={schemaType}
      title={title}
      description={description}
      datePublished={schemaDate}
      image={ogImage}
      url={canonicalURL}
    />

    <link rel="preconnect" href="https://images.unsplash.com" />

    <!-- Preload critical fonts (Vietnamese subset) — only the variants used above the fold. -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts/cormorant-garamond-vn-400.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-vn-400.woff2" crossorigin />

    {/* Fonts now self-hosted in /fonts/ — see src/styles/fonts.css */}
  </head>
  <body>
    <a href="#main" class="skip-to-main">Bỏ qua điều hướng — đến nội dung chính</a>
    <main id="main"><slot /></main>

    <script>
      import { initReveal } from '../lib/reveal';
      import { applyStoredDensity } from '../lib/density';
      applyStoredDensity();
      // Defer reveal init until next frame so initial layout is settled.
      requestAnimationFrame(initReveal);
    </script>

    {cfToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={cfBeaconConfig}
      />
    )}
  </body>
</html>
