---
import '../styles/global.css';
import site from '../data/site.yml';
import theme from '../data/theme.yml';
import StructuredData from '../components/StructuredData.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  /** Schema.org type — defaults to website. Use 'article' for blog, 'project' for case study. */
  schemaType?: 'website' | 'article' | 'project';
  schemaDate?: string;
}

const {
  title = `WOTU — ${site.tagline}`,
  description = site.description,
  ogImage,
  ogImageAlt = 'WOTU — Studio thiết kế & thi công nội thất, Quy Nhơn',
  schemaType = 'website',
  schemaDate,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
// Default OG: branded 1200×630 (public/og.png) — nhận diện thương hiệu khi share.
// Page có thể override bằng ảnh riêng (vd hero dự án) qua prop ogImage.
const ogImageURL = ogImage ?? new URL('/og.png', Astro.site).href;

// Cloudflare Web Analytics — only inject if token is configured.
const cfToken = (site.analytics?.cfBeaconToken ?? '').trim();
const cfBeaconConfig = cfToken ? JSON.stringify({ token: cfToken }) : '';

// Theme studio (tuỳ biến qua admin). Override --earth/--accent trên html[data-theme]
// (specificity > :root → luôn thắng, không phụ thuộc thứ tự CSS). Default = hiện tại.
// Chỉ giữ ký tự hợp lệ cho màu CSS — chặn breakout khỏi <style set:html>
// (vd giá trị "x}</style><script>…" từ theme.yml bị tamper).
const sanitizeColor = (v: unknown, fallback: string) => {
  const c = String(v ?? '').trim().replace(/[^a-zA-Z0-9#(),.%\s-]/g, '');
  return c || fallback;
};
const studioEarth = sanitizeColor(theme?.studio?.earth, '#6B5C45');
const studioAccent = sanitizeColor(theme?.studio?.accent, '#B8835A');
const studioThemeCss = `html[data-theme]{--earth:${studioEarth};--accent:${studioAccent};}`;
---
<!DOCTYPE html>
<html lang="vi" data-theme>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://images.unsplash.com https://avatars.githubusercontent.com; connect-src 'self' https://api.web3forms.com https://api.github.com https://github.com https://unpkg.com https://cloudflareinsights.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self' https://github.com https://api.web3forms.com;" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style set:html={studioThemeCss} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="vi_VN" />
    <meta property="og:site_name" content="WOTU" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- Structured data: LocalBusiness + WebSite + page-specific schema -->
    <StructuredData
      type={schemaType}
      title={title}
      description={description}
      datePublished={schemaDate}
      image={ogImageURL}
      url={canonicalURL}
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" />

    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#main" class="skip-to-main">Bỏ qua điều hướng — đến nội dung chính</a>
    <main id="main"><slot /></main>

    <script>
      import { initReveal } from '../lib/reveal';
      import { applyStoredDensity } from '../lib/density';
      applyStoredDensity();
      // Defer reveal init until next frame so initial layout is settled.
      requestAnimationFrame(initReveal);
    </script>

    {/* Xem trước trực tiếp cho admin — tự gate ?cms=1, no-op trên trang công khai */}
    <script>
      import '../scripts/cms-preview.ts';
    </script>

    {cfToken && (
      <script is:inline set:html={`
        if (location.search.indexOf('cms=1') < 0) {
          var s = document.createElement('script');
          s.defer = true;
          s.src = 'https://static.cloudflareinsights.com/beacon.min.js';
          s.setAttribute('data-cf-beacon', ${JSON.stringify(cfBeaconConfig)});
          document.head.appendChild(s);
        }
      `} />
    )}
  </body>
</html>
