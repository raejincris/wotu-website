---
import '../styles/shop.css';
import site from '../data/site.yml';
import theme from '../data/theme.yml';
import CartDrawer from '../components/shop/CartDrawer.astro';
import StructuredData from '../components/StructuredData.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: string;
}

const {
  title = `WOTU — Nội thất cho tổ ấm Việt`,
  description = 'WOTU — combo nội thất phòng khách, phòng ngủ, phòng ăn. Gỗ tự nhiên, bảo hành 5 năm, giao và lắp đặt tận nơi tại Quy Nhơn.',
  ogImage,
  ogImageAlt = 'WOTU — Nội thất Quy Nhơn',
  ogType = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
// Default OG: branded 1200×630 (public/og.png) — link preview Facebook/Zalo có
// nhận diện thương hiệu kể cả khi page không pass prop.
const ogImageURL = ogImage ?? new URL('/og.png', Astro.site).href;

const cfToken = (site.analytics?.cfBeaconToken ?? '').trim();
const cfBeaconConfig = cfToken ? JSON.stringify({ token: cfToken }) : '';

// Theme (tuỳ biến qua admin). palette/density dùng preset có sẵn trong shop.css;
// accent override (nếu có) đặt trên body.shop (specificity > preset → luôn thắng).
// Chỉ giữ ký tự hợp lệ cho màu CSS — chặn breakout khỏi <style set:html>
// (vd giá trị "red}</style><script>…" từ theme.yml bị tamper).
const sanitizeColor = (v: unknown) => String(v ?? '').trim().replace(/[^a-zA-Z0-9#(),.%\s-]/g, '');
const shopPalette = theme?.shop?.palette || 'warm';
const shopDensity = theme?.shop?.density || 'comfy';
const shopAccent = sanitizeColor(theme?.shop?.accent);
const shopAccentDeep = sanitizeColor(theme?.shop?.accentDeep);
const shopAccentCss = [
  shopAccent ? `--shop-accent:${shopAccent};` : '',
  shopAccentDeep ? `--shop-accent-deep:${shopAccentDeep};` : '',
].join('');
---
<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https://images.unsplash.com https://avatars.githubusercontent.com; connect-src 'self' https://api.web3forms.com https://api.github.com https://github.com https://unpkg.com https://cloudflareinsights.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self' https://github.com https://api.web3forms.com;" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="vi_VN" />
    <meta property="og:site_name" content="WOTU" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- Structured data: LocalBusiness + WebSite (cùng schema với studio) -->
    <StructuredData
      type="website"
      title={title}
      description={description}
      image={ogImageURL}
      url={canonicalURL}
    />
    <!-- Page-specific JSON-LD (FAQ, Product, Breadcrumb) từ page inject vào đây -->
    <slot name="head" />

    <!-- Preload critical woff2 (VN + Latin) — self-hosted, không CDN, không blocking. -->
    <link rel="preload" href="/fonts/cormorant-normal-400-vn.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/cormorant-normal-400-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-normal-400-vn.woff2" as="font" type="font/woff2" crossorigin />
    {shopAccentCss && <style set:html={`body.shop{${shopAccentCss}}`} />}
  </head>
  <body class="shop" data-shop-palette={shopPalette} data-shop-density={shopDensity}>
    <a href="#main" class="skip-to-main">Bỏ qua điều hướng — đến nội dung chính</a>
    <main id="main" data-pagefind-body><slot /></main>
    <CartDrawer />

    <script is:inline>
      // Reveal-on-scroll cho shop. Reveal ngay element đang trong viewport
      // (covers prerendered / no-IO browser); IO progressively reveal phần còn lại.
      (function () {
        // Reveal cả hệ cũ (.shop-reveal*) lẫn hệ studio port sang (.reveal* qua
        // [data-reveal]) — chung 1 trigger .is-visible.
        var els = document.querySelectorAll('.shop-reveal, .shop-reveal-stagger, [data-reveal]');
        if (!els.length) return;

        function revealVisible() {
          var vh = window.innerHeight;
          els.forEach(function (el) {
            var r = el.getBoundingClientRect();
            if (r.top < vh * 0.92 && r.bottom > 0) el.classList.add('is-visible');
          });
        }
        revealVisible();

        if ('IntersectionObserver' in window) {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            });
          }, { threshold: 0.08, rootMargin: '0px 0px -6% 0px' });
          els.forEach(function (el) { io.observe(el); });
        } else {
          window.addEventListener('scroll', revealVisible, { passive: true });
        }
        // Safety net: nếu vì lý do gì element không bao giờ trigger, hiện hết sau 1.5s.
        setTimeout(function () { els.forEach(function (el) { el.classList.add('is-visible'); }); }, 1500);
      })();
    </script>

    {/* Xem trước trực tiếp cho admin — tự gate ?cms=1, no-op trên trang công khai */}
    <script>
      import '../scripts/cms-preview.ts';
    </script>

    {cfToken && (
      <script is:inline set:html={`
        if (location.search.indexOf('cms=1') < 0) {
          var s = document.createElement('script');
          s.defer = true;
          s.src = 'https://static.cloudflareinsights.com/beacon.min.js';
          s.setAttribute('data-cf-beacon', ${JSON.stringify(cfBeaconConfig)});
          document.head.appendChild(s);
        }
      `} />
    )}
  </body>
</html>
