---
import footer from '../data/footer.yml';
import { SITE_VERSION } from '../lib/version';
import { navPages } from '../lib/custom-pages';

interface Link { label: string; href: string; }
interface Column { title: string; links: Link[]; }
const cols = (footer.columns as Column[]).map((c) => ({ ...c, links: [...c.links] }));

// Trang tuỳ chỉnh (admin) gắn cờ hiện-menu → thêm vào cột cuối của footer Studio.
const extraPages = navPages('studio');
if (extraPages.length && cols.length) {
  cols[cols.length - 1].links.push(...extraPages.map((p) => ({ label: p.title, href: `/${p.slug}/` })));
}

const isExternal = (href: string) => /^https?:\/\//.test(href);
---
<footer style="background: var(--cocoa); color: var(--clay); padding: 64px var(--pad-x) 32px; border-top: 1px solid rgba(245,240,232,0.1);">
  <div class="footer-grid" style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; padding-bottom: 64px; border-bottom: 1px solid rgba(245,240,232,0.1);">
    <div>
      <a href="/studio/" aria-label="WOTU Studio — về trang chủ" style="display: inline-block;">
        <img src="/logo-light.svg" alt="WOTU" width="200" height="82" loading="lazy" decoding="async" style="height: 56px; width: auto; display: block;" />
      </a>
      <p style="margin-top: 16px; font-size: 13px; color: var(--clay); max-width: 32ch; line-height: 1.6;" set:html={footer.tagline}></p>
    </div>
    {cols.map((c) => (
      <div>
        <div style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--earth); margin-bottom: 16px;">{c.title}</div>
        <div style="display: flex; flex-direction: column; gap: 10px;">
          {c.links.map((x) => (
            <a
              href={x.href}
              style="font-size: 14px; color: var(--bone);"
              target={isExternal(x.href) ? '_blank' : undefined}
              rel={isExternal(x.href) ? 'noopener noreferrer' : undefined}
            >{x.label}</a>
          ))}
        </div>
      </div>
    ))}
  </div>
  <div class="footer-bottom" style="padding-top: 24px; display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; color: var(--earth); text-transform: uppercase;">
    <div>{footer.copyright} <span style="opacity: 0.6;">· v{SITE_VERSION}</span></div>
    <div>{footer.signature}</div>
  </div>
</footer>

<style>
  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: 1fr 1fr !important; gap: 32px !important; }
    .footer-bottom { flex-direction: column; gap: 8px; }
  }
  /* Galaxy S5 / iPhone SE narrow — 4 cột stack hết thành 1 cột */
  @media (max-width: 480px) {
    .footer-grid { grid-template-columns: 1fr !important; gap: 24px !important; }
  }

  /* Touch target for footer links */
  footer a {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
  }
</style>
