---
import Reveal from './Reveal.astro';
import SplitWords from './SplitWords.astro';
import home from '../data/home.yml';
import site from '../data/site.yml';

const c = home.contact;

interface Field {
  label: string;
  name: string;
  type: string;
  placeholder?: string;
}
const fields = c.fields as Field[];

const accessKey = site.forms?.contactAccessKey ?? '';
const subject = site.forms?.contactSubject ?? '[WOTU] Liên hệ mới từ website';
---
<section id="contact" style="padding: var(--pad-section) var(--pad-x); background: var(--cocoa); color: var(--bone);">
  <div class="grid-2col" style="display: grid; grid-template-columns: 1.2fr 1fr; gap: var(--gap); align-items: start;">
    <Reveal variant="reveal" delay={0}>
      <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em; color: var(--clay); text-transform: uppercase; margin-bottom: 24px;">{c.number} · {c.label}</div>
      <SplitWords
        tag="h2"
        base={100}
        step={90}
        text={c.heading}
        style="font-family: var(--font-display); font-weight: 400; font-size: clamp(56px, 8vw, 140px); line-height: 1.0; color: var(--bone);"
      />
      <div style="margin-top: 64px; display: grid; grid-template-columns: 1fr 1fr; gap: 32px; max-width: 480px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; color: var(--clay); text-transform: uppercase;">
        <div>
          <div style="color: var(--taupe); margin-bottom: 8px;">Studio</div>
          <div>{site.address.line1},<br/>{site.address.city}</div>
        </div>
        <div>
          <div style="color: var(--taupe); margin-bottom: 8px;">Liên lạc</div>
          <div>{site.hotline}<br/>{site.email}</div>
        </div>
      </div>
    </Reveal>

    <Reveal variant="reveal" delay={400} style="padding-top: 32px;">
      <form id="wotu-contact-form" style="display: flex; flex-direction: column; gap: 32px;">
        <input type="hidden" name="access_key" value={accessKey} />
        <input type="hidden" name="subject" value={subject} />
        <input type="hidden" name="from_name" value="WOTU Website" />
        <input type="hidden" name="redirect" value="false" />

        {/* Honeypot — must remain empty; visible-but-aria-hidden trap for bots that ignore display:none */}
        <div style="position: absolute; left: -10000px; opacity: 0; pointer-events: none;" aria-hidden="true">
          <label>Đừng điền vào ô này</label>
          <input type="text" name="botcheck" tabindex="-1" autocomplete="off" />
        </div>

        {fields.map((f) => {
          const fieldId = `wotu-contact-${f.name}`;
          return (
            <div style="display: flex; flex-direction: column; gap: 8px;">
              <label for={fieldId} style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--clay);">
                {f.label}
                {f.name !== 'phone' && <span style="color: var(--accent); margin-left: 4px;">*</span>}
              </label>
              {f.type === 'textarea' ? (
                <textarea id={fieldId} name={f.name} rows={2} placeholder={f.placeholder} required style="width: 100%; background: transparent; border: none; border-bottom: 1px solid rgba(245,240,232,0.25); padding: 12px 0; font-family: var(--font-display); font-size: 22px; color: var(--bone); outline: none; resize: none;"></textarea>
              ) : (
                <input
                  id={fieldId}
                  name={f.name}
                  type={f.type}
                  placeholder={f.placeholder}
                  required={f.name !== 'phone'}
                  style="width: 100%; background: transparent; border: none; border-bottom: 1px solid rgba(245,240,232,0.25); padding: 12px 0; font-family: var(--font-display); font-size: 22px; color: var(--bone); outline: none;"
                />
              )}
            </div>
          );
        })}

        <button type="submit" id="wotu-contact-submit" style="margin-top: 16px; padding: 18px 32px; min-height: 48px; font-family: var(--font-sans); font-size: 12px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; border: 1px solid var(--bone); background: var(--bone); color: var(--ink); cursor: pointer; align-self: start; transition: opacity 200ms;">
          {c.submitLabel}
        </button>

        <div id="wotu-contact-feedback" role="status" aria-live="polite" style="font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.06em; color: var(--clay); min-height: 1em;"></div>
      </form>
    </Reveal>
  </div>
</section>

<script>
  const form = document.getElementById('wotu-contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('wotu-contact-submit') as HTMLButtonElement | null;
  const feedback = document.getElementById('wotu-contact-feedback') as HTMLDivElement | null;

  if (form && submitBtn && feedback) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const data = new FormData(form);

      // Honeypot — bot fills this, real users don't.
      if ((data.get('botcheck') ?? '').toString().length > 0) {
        feedback.textContent = '';
        return;
      }

      submitBtn.disabled = true;
      submitBtn.style.opacity = '0.5';
      submitBtn.textContent = 'Đang gửi…';
      feedback.style.color = 'var(--clay)';
      feedback.textContent = '';

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
          },
          body: JSON.stringify(Object.fromEntries(data)),
        });
        const json = await response.json();

        if (response.ok && json.success) {
          form.reset();
          feedback.style.color = 'var(--accent)';
          feedback.textContent =
            (form.dataset.successMessage as string | undefined) ??
            'Cảm ơn bạn — chúng tôi sẽ liên hệ trong 24h.';
          submitBtn.textContent = 'Đã gửi ✓';
        } else {
          throw new Error(json.message || 'Server returned an error.');
        }
      } catch (err) {
        feedback.style.color = '#E07a5F';
        feedback.textContent =
          'Có lỗi xảy ra. Vui lòng thử lại hoặc gọi trực tiếp ' +
          ((document.querySelector('[data-hotline]') as HTMLElement | null)?.textContent ?? 'hotline');
        submitBtn.disabled = false;
        submitBtn.style.opacity = '1';
        submitBtn.textContent = (form.dataset.submitLabel as string | undefined) ?? 'Gửi yêu cầu';
      }
    });
  }
</script>

<style>
  section :global(h2 em) { font-style: italic; color: var(--accent); }
</style>
