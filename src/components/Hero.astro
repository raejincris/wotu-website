---
import Reveal from './Reveal.astro';
import SplitWords from './SplitWords.astro';
import Placeholder from './Placeholder.astro';
import home from '../data/home.yml';
import site from '../data/site.yml';
---
<section style="position: relative; min-height: 100vh; padding-top: 100px; padding-left: var(--pad-x); padding-right: var(--pad-x); padding-bottom: 64px; display: flex; flex-direction: column; justify-content: space-between;">

  <div class="hero-meta" style="display: flex; justify-content: space-between; gap: 16px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em; color: var(--earth); text-transform: uppercase; margin-top: 24px;">
    <div style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; min-width: 0;">EST · {site.meta.est} — {site.meta.location}</div>
    <div style="white-space: nowrap;">SỐ {site.meta.issueNumber}</div>
  </div>

  <div style="margin-top: 80px; margin-bottom: 64px;">
    <Reveal variant="reveal" delay={100} style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.22em; color: var(--earth); text-transform: uppercase; margin-bottom: 32px;">
      {home.hero.eyebrow}
    </Reveal>
    <SplitWords
      tag="h1"
      base={300}
      step={90}
      text={home.hero.title}
      style="font-family: var(--font-display); font-weight: 400; font-size: clamp(64px, 12vw, 200px); line-height: 1.0; letter-spacing: -0.025em; color: var(--bark);"
    />
  </div>

  <div class="hero-bottom grid-2col" style="display: grid; grid-template-columns: 1fr 480px; gap: var(--gap); align-items: end;">
    <div style="font-family: var(--font-sans); font-size: 15px; color: var(--earth); max-width: 380px; line-height: 1.6;">
      {home.hero.intro}
      <div style="margin-top: 24px; display: flex; align-items: center; gap: 12px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink);">
        <a href="#about" style="display: inline-flex; align-items: center; min-height: 44px; padding: 12px 0; border-bottom: 1px solid var(--ink);">{home.hero.cta}</a>
        <span>↓</span>
      </div>
    </div>
    <Reveal variant="reveal-img" delay={500}>
      <Placeholder
        label="HERO · INTERIOR · LIVING ROOM 4:5"
        ratio="4/5"
        tone="warm"
        photo={home.hero.heroImage}
        alt={home.hero.heroAlt}
        sizes="(max-width: 768px) 100vw, 480px"
        priority
      />
    </Reveal>
  </div>
</section>

<style>
  section :global(h1 em) { font-style: italic; color: var(--earth); }

  @media (max-width: 768px) {
    /* Hero heading on mobile — keep consistent with desktop now that line-height is already 1.0. */
    section :global(h1) { line-height: 1.0 !important; }
  }
</style>
