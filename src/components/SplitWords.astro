---
// SplitWords — splits a string into words, each wrapped in an inline-block
// clipper with a staggered .reveal-rise child. Supports raw HTML in `text`
// (e.g. <em>...</em>, <br/>) by tokenising on whitespace OUTSIDE tags.

interface Props {
  /**
   * Trusted author HTML only. Tokens matching `<em>...</em>` and self-closing
   * tags (e.g. `<br/>`) are emitted via `set:html` without sanitisation.
   * Never pass user-generated or fetched content here — XSS would follow.
   */
  text: string;
  base?: number;
  step?: number;
  tag?: keyof HTMLElementTagNameMap;
  class?: string;
  style?: string;
}

const {
  text,
  base = 0,
  step = 60,
  tag = 'h1',
  class: className = '',
  style = '',
} = Astro.props;

// Tokenise the input string. We split on whitespace at the top level (depth 0
// of HTML tag nesting). Whitespace is preserved as plain text between word
// spans. <br/> and <em>...</em> are kept inline; <em>'s text is treated as a
// single visual unit (one stagger slot) for simplicity — matches the prototype
// for the headlines used.
type Token = { kind: 'word' | 'html' | 'space'; value: string };
const tokens: Token[] = [];

let buf = '';
let depth = 0;
let i = 0;
const n = text.length;

const flushWord = () => {
  if (!buf) return;
  if (/^\s+$/.test(buf)) tokens.push({ kind: 'space', value: buf });
  else tokens.push({ kind: 'word', value: buf });
  buf = '';
};

while (i < n) {
  const ch = text[i];
  if (ch === '<') {
    flushWord();
    // Read full tag including its body if it has a closing pair on same level
    const start = i;
    // self-closing or simple tag — read until matching '>'
    while (i < n && text[i] !== '>') i++;
    i++; // consume '>'
    const tagStr = text.slice(start, i);
    // void / self-close (e.g. <br/>) — emit as html token
    if (/^<\w[^>]*\/>/.test(tagStr) || /^<br\s*\/?>$/i.test(tagStr)) {
      tokens.push({ kind: 'html', value: tagStr });
      continue;
    }
    // open tag — read until matching close at same depth
    const tagNameMatch = tagStr.match(/^<\s*([a-zA-Z][\w-]*)/);
    const tagName = tagNameMatch ? tagNameMatch[1] : '';
    if (!tagName) {
      tokens.push({ kind: 'html', value: tagStr });
      continue;
    }
    let inner = '';
    depth = 1;
    while (i < n && depth > 0) {
      if (text[i] === '<') {
        // peek
        const m = text.slice(i).match(/^<\s*(\/?)\s*([a-zA-Z][\w-]*)/);
        if (m) {
          if (m[1] === '/' && m[2] === tagName) depth--;
          else if (m[1] !== '/' && m[2] === tagName) depth++;
        }
      }
      if (depth === 0) break;
      inner += text[i];
      i++;
    }
    // consume closing tag
    while (i < n && text[i] !== '>') i++;
    i++;
    tokens.push({ kind: 'html', value: `<${tagName}>${inner}</${tagName}>` });
    continue;
  }
  if (/\s/.test(ch)) {
    if (!/^\s/.test(buf)) flushWord();
    buf += ch;
    if (i + 1 < n && !/\s/.test(text[i + 1])) flushWord();
  } else {
    if (/^\s/.test(buf)) flushWord();
    buf += ch;
  }
  i++;
}
flushWord();

let wi = 0;
const Tag = tag;
---
<Tag class={className} style={style}>
  {tokens.map((t) => {
    if (t.kind === 'space') return t.value;
    if (t.kind === 'html') {
      // <br/> must NOT be wrapped in an inline-block span — doing so contains the
      // line-break inside the block and prevents it from breaking the parent line.
      // Output bare <br> elements; other HTML tags (em, span) still get the stagger wrapper.
      if (/^<br[\s/]*>/i.test(t.value.trim())) {
        return <br />;
      }
      const delay = base + wi * step;
      wi += 1;
      return (
        <span class="reveal-rise" data-reveal style={`--rev-delay: ${delay}ms; display: inline-block; padding-top: 0.25em; margin-top: -0.25em;`} set:html={t.value} />
      );
    }
    const delay = base + wi * step;
    wi += 1;
    return (
      <span class="sw-word">
        <span class="reveal-rise" data-reveal style={`--rev-delay: ${delay}ms;`}>{t.value}</span>
      </span>
    );
  })}
</Tag>
