---
/**
 * BlockRenderer — dispatch 1 khối nội dung động theo `block.type`.
 * Thêm loại khối mới = thêm component + 1 dòng vào REGISTRY (và admin block-types.js).
 */
import RichText from './RichText.astro';
import BannerCta from './BannerCta.astro';

interface Props { block: any; }
const { block } = Astro.props;

const REGISTRY: Record<string, any> = {
  richText: RichText,
  bannerCta: BannerCta,
};
const C = REGISTRY[block?.type];
---
{C ? <C block={block} /> : null}
