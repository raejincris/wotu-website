---
/* Section "Đã xem gần đây" — render client-side từ localStorage (recordView/
 * getRecent trong shop-store). Catalog lookup từ shop-catalog (build-time data).
 * `hidden` mặc định, chỉ hiện khi có ≥1 item khác trang hiện tại — section nằm
 * below-fold nên không gây CLS đáng kể.
 *
 * Props:
 *  - exclude: id sản phẩm của trang hiện tại (không show lại chính nó)
 *  - heading: tiêu đề section (mặc định "Bạn vừa xem") */
import { catalogJson } from '../../lib/shop-catalog';

interface Props { exclude?: string; heading?: string; }
const { exclude = '', heading = 'Bạn vừa xem' } = Astro.props;
const json = catalogJson();
---
<section class="rv container" id="wotu-recent" hidden data-exclude={exclude}>
  <h2 class="rv-head">{heading}</h2>
  <div class="rv-grid" id="wotu-recent-grid"></div>
</section>

<script is:inline define:vars={{ json }}>
  // Catalog chung cho mọi consumer client-side (wishlist dùng cùng biến này).
  window.__wotuCatalog = window.__wotuCatalog || JSON.parse(json);
</script>

<script>
  import { getRecent } from '../../lib/shop-store';

  interface CatalogEntry {
    id: string; name: string; meta: string; price: number;
    priceLabel: string; href: string; illo: string; placeholder: string;
  }

  const section = document.getElementById('wotu-recent');
  const grid = document.getElementById('wotu-recent-grid');

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));
  }

  if (section && grid) {
    const catalog: CatalogEntry[] =
      (window as unknown as { __wotuCatalog?: CatalogEntry[] }).__wotuCatalog ?? [];
    const byId = new Map(catalog.map((c) => [c.id, c]));
    const exclude = section.dataset.exclude ?? '';

    const items = getRecent()
      .filter((id) => id !== exclude)
      .map((id) => byId.get(id))
      .filter((x): x is CatalogEntry => !!x)
      .slice(0, 4);

    if (items.length > 0) {
      grid.innerHTML = items
        .map(
          (it) => `
            <a class="rv-card" href="${escapeHtml(it.href)}">
              <div class="rv-img">
                <div class="shop-ph"><span class="shop-ph-label">${escapeHtml(it.placeholder)}</span></div>
                <img class="shop-illo" src="${escapeHtml(it.illo)}" alt="${escapeHtml(it.name)}" loading="lazy" decoding="async" />
              </div>
              <div class="rv-body">
                <span class="rv-meta">${escapeHtml(it.meta)}</span>
                <h3>${escapeHtml(it.name)}</h3>
                <div class="rv-price">${escapeHtml(it.priceLabel)}</div>
              </div>
            </a>
          `,
        )
        .join('');
      section.hidden = false;
    }
  }
</script>

<style>
  .rv { padding-top: 0 !important; }
  .rv-head {
    font-family: var(--shop-serif); font-weight: 400;
    font-size: clamp(26px, 3.5vw, 38px); margin: 0 0 24px;
  }
  .rv-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }
  /* Card render qua innerHTML → mất data-astro-cid → cần :global() (bài học wl-card). */
  :global(.rv-card) {
    background: var(--shop-bg-card); border-radius: var(--shop-radius-lg);
    overflow: hidden; display: flex; flex-direction: column;
    border: 1px solid color-mix(in oklab, var(--shop-line) 60%, transparent);
    transition: transform 0.25s, box-shadow 0.25s;
    color: var(--shop-ink); text-decoration: none;
  }
  :global(.rv-card:hover) { transform: translateY(-4px); box-shadow: 0 18px 36px -16px rgba(58, 42, 30, 0.16); }
  :global(.rv-img) { aspect-ratio: 4/3; position: relative; overflow: hidden; background: var(--shop-bg-soft); }
  :global(.rv-body) { padding: 14px 16px 16px; display: flex; flex-direction: column; gap: 5px; }
  :global(.rv-meta) { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--shop-ink-soft); font-weight: 600; }
  :global(.rv-body h3) { font-family: var(--shop-serif); font-weight: 400; font-size: 19px; line-height: 1.1; margin: 0; }
  :global(.rv-price) { font-family: var(--shop-serif); font-size: 16px; margin-top: 2px; }
  @media (max-width: 980px) { .rv-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
