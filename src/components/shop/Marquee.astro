---
const items = [
  'Gỗ tự nhiên 100%',
  'Bảo hành 5 năm',
  'Miễn phí giao & lắp đặt',
  'Đổi trả trong 30 ngày',
  { italic: 'Combo trọn gói — 7 ngày dọn vào ở' },
  'Tư vấn 1:1 miễn phí',
];
---
<div class="shop-marquee">
  <div class="shop-marquee-track">
    <span>
      {items.map((item) => (
        <>
          {typeof item === 'string'
            ? <span>{item}</span>
            : <i>{item.italic}</i>}
          <span class="star" aria-hidden="true"></span>
        </>
      ))}
    </span>
    <span aria-hidden="true">
      {items.map((item) => (
        <>
          {typeof item === 'string'
            ? <span>{item}</span>
            : <i>{item.italic}</i>}
          <span class="star" aria-hidden="true"></span>
        </>
      ))}
    </span>
  </div>
</div>
