---
/* Nút "Lên đầu trang" cho các trang dài (catalog, sofa-may, combo detail).
 * Hiện khi cuộn quá ~1.2 màn hình. Smooth scroll đã có sẵn ở shop.css
 * (html:has(body.shop) + reduced-motion auto). Chỉ opacity/transform → 0 CLS. */
---
<button type="button" id="wotu-btt" class="btt" aria-label="Lên đầu trang" tabindex="-1">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
</button>

<style>
  .btt {
    position: fixed; right: 22px; bottom: 22px; z-index: 60;
    width: 46px; height: 46px; border-radius: 50%;
    background: var(--shop-ink); color: var(--shop-bg);
    border: 0; cursor: pointer;
    display: grid; place-items: center;
    box-shadow: 0 14px 30px -12px rgba(20, 16, 12, 0.4);
    opacity: 0; transform: translateY(14px); pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease, background 0.2s;
  }
  .btt.on { opacity: 1; transform: none; pointer-events: auto; }
  .btt:hover { background: var(--shop-accent-deep); }
  /* Mobile: nhường chỗ cho sticky add-to-cart bar (nếu trang có). */
  @media (max-width: 860px) {
    .btt { bottom: 86px; right: 16px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .btt { transition: none; }
  }
</style>

<script>
  const btn = document.getElementById('wotu-btt');
  if (btn) {
    let ticking = false;
    const update = () => {
      ticking = false;
      const on = window.scrollY > window.innerHeight * 1.2;
      btn.classList.toggle('on', on);
      btn.setAttribute('tabindex', on ? '0' : '-1');
    };
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) { ticking = true; requestAnimationFrame(update); }
      },
      { passive: true },
    );
    update();
    btn.addEventListener('click', () => window.scrollTo({ top: 0 }));
  }
</script>
