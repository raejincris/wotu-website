---
import Reveal from './Reveal.astro';
import home from '../data/home.yml';

const a = home.about;

interface Stat { n: string; l: string; }
const stats = a.stats as Stat[];
---
<section id="about" style="padding: var(--pad-section) var(--pad-x);">
  <div class="grid-2col" style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap); align-items: start;">
    <Reveal variant="reveal" delay={0}>
      <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em; color: var(--earth); text-transform: uppercase; margin-bottom: 16px;">{a.number} · {a.label}</div>
      <h2 style="font-family: var(--font-display); font-weight: 400; font-size: clamp(48px, 6vw, 88px); line-height: 0.95; letter-spacing: -0.02em; color: var(--bark); margin-bottom: 32px;" set:html={a.heading.replace(/<em>/g, '<em style="font-style: italic; color: var(--earth);">')}></h2>
      <p style="font-size: 17px; line-height: 1.7; color: var(--ink); max-width: 42ch; margin-bottom: 32px;">
        {a.body}
      </p>
      <a href="#contact" style="display: inline-flex; align-items: center; gap: 12px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink); border-bottom: 1px solid var(--ink); padding-bottom: 4px;">{a.ctaLabel} <span>→</span></a>
    </Reveal>

    <div class="grid-2col stats-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 48px; padding-top: 24px;">
      {stats.map((s, i) => (
        <Reveal variant="reveal" delay={150 + i * 100} style="border-top: 1px solid var(--ink); padding-top: 16px;">
          <div style="font-family: var(--font-display); font-weight: 300; font-size: clamp(56px, 6vw, 88px); line-height: 0.9; letter-spacing: -0.02em; color: var(--bark);">{s.n}</div>
          <div style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--earth); margin-top: 16px; line-height: 1.6;">{s.l}</div>
        </Reveal>
      ))}
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    .stats-grid { padding-top: 0 !important; }
  }
</style>
