---
/**
 * Newsletter.astro — thu email nhận tin, submit qua Web3Forms (reuse access key
 * trong site.yml — không cần dịch vụ ngoài). Dùng cho cả Shop và Studio footer
 * qua prop `variant` (đổi token màu theo design system của từng phần).
 */
import site from '../data/site.yml';
const accessKey = site.forms?.contactAccessKey ?? '';

interface Props {
  variant?: 'shop' | 'studio';
  heading?: string;
  sub?: string;
}
const {
  variant = 'studio',
  heading = 'Nhận thư từ WOTU',
  sub = 'Thỉnh thoảng — vài ghi chép về không gian sống, vật liệu và ưu đãi. Không spam, huỷ bất cứ lúc nào.',
} = Astro.props;
---
<section class={`nl nl-${variant}`}>
  <div class="nl-text">
    <h3>{heading}</h3>
    <p>{sub}</p>
  </div>
  <form class="nl-form" data-success="Cảm ơn bạn đã đăng ký nhận tin từ WOTU 🌿">
    <input type="hidden" name="access_key" value={accessKey} />
    <input type="hidden" name="subject" value="[WOTU website] Đăng ký nhận tin (newsletter)" />
    <input type="hidden" name="from_name" value="WOTU Newsletter" />
    <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;opacity:0;" aria-hidden="true" />
    <input class="nl-input" type="email" name="email" required placeholder="Email của bạn" aria-label="Email" autocomplete="email" />
    <button class="nl-btn" type="submit">Đăng ký</button>
    <p class="nl-feedback" role="status" aria-live="polite"></p>
  </form>
</section>

<script>
  document.querySelectorAll<HTMLFormElement>('.nl-form').forEach((form) => {
    const btn = form.querySelector<HTMLButtonElement>('.nl-btn');
    const fb = form.querySelector<HTMLParagraphElement>('.nl-feedback');
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      if ((data.get('botcheck') ?? '').toString().length > 0) return; // honeypot
      if (btn) { btn.disabled = true; btn.textContent = 'Đang gửi…'; }
      if (fb) { fb.textContent = ''; fb.classList.remove('err'); }
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(Object.fromEntries(data)),
        });
        const json = await res.json();
        if (res.ok && json.success) {
          form.reset();
          if (fb) fb.textContent = form.dataset.success ?? 'Cảm ơn bạn đã đăng ký!';
          if (btn) btn.textContent = 'Đã đăng ký ✓';
        } else { throw new Error(json.message || 'error'); }
      } catch {
        if (fb) { fb.textContent = 'Có lỗi xảy ra, vui lòng thử lại.'; fb.classList.add('err'); }
        if (btn) { btn.disabled = false; btn.textContent = 'Đăng ký'; }
      }
    });
  });
</script>

<style>
  .nl { display: flex; flex-wrap: wrap; gap: 24px 48px; align-items: center; justify-content: space-between; }
  .nl-text h3 { font-weight: 400; line-height: 1.1; margin: 0; }
  .nl-text p { margin: 8px 0 0; max-width: 46ch; font-size: 14px; line-height: 1.55; }
  .nl-form { display: grid; grid-template-columns: 1fr auto; gap: 10px; min-width: min(420px, 100%); position: relative; }
  .nl-input { font: inherit; font-size: 15px; padding: 14px 16px; border-radius: 8px; outline: none; width: 100%; }
  .nl-btn { font-size: 14px; font-weight: 600; padding: 14px 24px; border-radius: 8px; border: 0; cursor: pointer; white-space: nowrap; transition: opacity .2s, background .2s; }
  .nl-btn:disabled { opacity: .6; cursor: default; }
  .nl-feedback { grid-column: 1 / -1; margin: 2px 0 0; font-size: 13px; min-height: 1em; }

  /* ── Studio (warm editorial) ── */
  .nl-studio { padding: 56px var(--pad-x); max-width: 1280px; margin: 0 auto; border-top: 1px solid var(--line); }
  .nl-studio h3 { font-family: var(--font-display); font-size: clamp(28px, 3.5vw, 40px); color: var(--bark); }
  .nl-studio p { font-family: var(--font-sans); color: var(--earth); }
  .nl-studio .nl-input { border: 1px solid var(--line); background: var(--bone); color: var(--ink); }
  .nl-studio .nl-input:focus { border-color: var(--earth); }
  .nl-studio .nl-btn { background: var(--ink); color: var(--bone); font-family: var(--font-mono); letter-spacing: .08em; text-transform: uppercase; }
  .nl-studio .nl-btn:hover:not(:disabled) { background: var(--cocoa); }
  .nl-studio .nl-feedback { color: var(--earth); }

  /* ── Shop (cream + terracotta) ── */
  .nl-shop { padding: 48px 28px; max-width: var(--shop-maxw); margin: 0 auto; border-top: 1px solid var(--shop-line); }
  .nl-shop h3 { font-family: var(--shop-serif); font-size: clamp(26px, 3.2vw, 38px); color: var(--shop-ink); }
  .nl-shop p { color: var(--shop-ink-soft); }
  .nl-shop .nl-input { border: 1px solid var(--shop-line); background: var(--shop-bg-card, #fff); color: var(--shop-ink); }
  .nl-shop .nl-input:focus { border-color: var(--shop-accent); }
  .nl-shop .nl-btn { background: var(--shop-accent); color: #fff; }
  .nl-shop .nl-btn:hover:not(:disabled) { background: var(--shop-accent-deep); }
  .nl-shop .nl-feedback { color: var(--shop-accent); }
  .nl-feedback.err { color: #c0492f !important; }

  @media (max-width: 720px) {
    .nl { flex-direction: column; align-items: stretch; }
    .nl-form { min-width: 0; }
  }
</style>
