---
import Reveal from './Reveal.astro';
import home from '../data/home.yml';

const q = home.quote;
---
<section style="padding: var(--pad-section) var(--pad-x); background: var(--linen);">
  <div class="grid-2col" style="display: grid; grid-template-columns: 1fr 1.6fr; gap: var(--gap); align-items: start;">
    <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em; color: var(--earth); text-transform: uppercase; padding-top: 16px;">{q.number} · {q.label}</div>
    <Reveal variant="reveal" delay={150}>
      <div style="font-family: var(--font-display); font-weight: 300; font-size: clamp(32px, 4vw, 64px); line-height: 1.15; color: var(--bark);">
        <span style="color: var(--accent);">“</span><span data-cms="quote.text">{q.text}</span><span style="color: var(--accent);">”</span>
      </div>
      <div class="quote-attr" style="margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--line); display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--earth);">
        <div data-cms="quote.author">{q.author}</div>
        <div data-cms="quote.year">{q.year}</div>
      </div>
    </Reveal>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    .quote-attr { flex-direction: column; gap: 8px; }
  }
</style>
