---
import footer from '../data/footer.yml';
import { navPages } from '../lib/custom-pages';

interface Props {
  variant?: 'home' | 'inner';
  /** Where the logo + home-anchor links point. Defaults to '/' (root).
   *  Studio inner pages pass '/studio/' so anchors return to the studio
   *  homepage rather than the shop homepage at root. */
  homeRoute?: string;
}
const { variant = 'home', homeRoute = '/' } = Astro.props;
const pathname = Astro.url.pathname;

interface NavLink { label: string; anchor?: string; route?: string; }
const navLinks = footer.nav.links as NavLink[];
const homeAnchor = variant === 'home' ? '#' : homeRoute;

const links = navLinks.map((l) => {
  const href = variant === 'home'
    ? (l.route ? l.route : `#${l.anchor}`)
    : (l.route ? l.route : `${homeRoute}#${l.anchor}`);
  const isRoute = href.startsWith('/') && !href.includes('#');
  const isCurrent = isRoute && (pathname === href || pathname.startsWith(href));
  return { label: l.label, href, isCurrent };
});

// Trang tuỳ chỉnh (admin) gắn cờ nav:true cho phần Studio → thêm vào cuối menu.
navPages('studio').forEach((p) => {
  const href = `/${p.slug}/`;
  links.push({ label: p.title, href, isCurrent: pathname === href || pathname.startsWith(href) });
});
---
<nav class="wotu-nav" style="position: fixed; top: 0; left: 0; right: 0; z-index: 50; padding: 16px var(--pad-x); display: flex; justify-content: space-between; align-items: center; color: var(--ink);">
  <a href={homeAnchor} class="wotu-nav-logo" aria-label="WOTU — về trang chủ">
    <img src="/logo.svg" alt="WOTU" width="118" height="48" />
  </a>

  <div class="wotu-nav-links" style="display: flex; gap: 36px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;">
    {links.map((l) => <a href={l.href} aria-current={l.isCurrent ? 'page' : undefined}>{l.label}</a>)}
  </div>

  <button
    type="button"
    class="wotu-nav-toggle"
    aria-label="Mở menu"
    aria-expanded="false"
    aria-controls="wotu-mobile-drawer"
  >
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<div
  id="wotu-mobile-drawer"
  class="wotu-mobile-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="Menu điều hướng"
  hidden
>
  <div class="wotu-mobile-drawer__inner">
    <div class="wotu-mobile-drawer__head">
      <a href={homeAnchor} aria-label="WOTU — về trang chủ" style="display: inline-flex; align-items: center;">
        <img src="/logo-light.svg" alt="WOTU" width="118" height="48" loading="lazy" decoding="async" style="height: 36px; width: auto;" />
      </a>
      <button type="button" class="wotu-mobile-drawer__close" aria-label="Đóng menu">×</button>
    </div>
    <nav class="wotu-mobile-drawer__nav">
      {links.map((l) => <a href={l.href} aria-current={l.isCurrent ? 'page' : undefined}>{l.label}</a>)}
    </nav>
  </div>
</div>

<style>
  /* Translucent backdrop so the logo + links stay readable when Nav crosses
     dark sections (Process, Contact, Footer). */
  .wotu-nav {
    background: linear-gradient(to bottom, rgba(245, 240, 232, 0.92), rgba(245, 240, 232, 0.75));
    backdrop-filter: saturate(140%) blur(8px);
    -webkit-backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid rgba(43, 35, 28, 0.06);
  }

  .wotu-nav-logo {
    display: inline-flex;
    align-items: center;
    height: 48px;
  }
  .wotu-nav-logo img {
    height: 36px;
    width: auto;
    display: block;
  }

  /* Hamburger button — only visible on mobile */
  .wotu-nav-toggle {
    display: none;
    width: 44px;
    height: 44px;
    padding: 12px;
    background: transparent;
    border: none;
    cursor: pointer;
    flex-direction: column;
    justify-content: space-between;
    align-items: stretch;
  }
  .wotu-nav-toggle span {
    display: block;
    height: 1.5px;
    width: 100%;
    background: var(--ink);
    transition: transform 280ms ease, opacity 200ms ease;
    transform-origin: center;
  }

  /* Mobile drawer */
  .wotu-mobile-drawer {
    position: fixed;
    inset: 0;
    z-index: 60;
    background: var(--cocoa);
    color: var(--bone);
    flex-direction: column;
    overflow-y: auto;
    opacity: 0;
    transition: opacity 240ms ease;
    /* Override browser [hidden]=display:none default with display:flex when NOT hidden */
    display: none;
  }
  .wotu-mobile-drawer:not([hidden]) {
    display: flex;
    opacity: 1;
  }
  .wotu-mobile-drawer__inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 20px var(--pad-x) var(--pad-x);
  }
  .wotu-mobile-drawer__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(245, 240, 232, 0.12);
  }
  .wotu-mobile-drawer__close {
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    color: var(--bone);
    font-size: 32px;
    line-height: 1;
    cursor: pointer;
  }
  .wotu-mobile-drawer__nav {
    display: flex;
    flex-direction: column;
    padding-top: 32px;
    gap: 4px;
  }
  .wotu-mobile-drawer__nav a {
    display: flex;
    align-items: center;
    min-height: 56px;
    padding: 16px 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 36px;
    color: var(--bone);
    border-bottom: 1px solid rgba(245, 240, 232, 0.08);
    transition: color 200ms ease;
  }
  .wotu-mobile-drawer__nav a:hover,
  .wotu-mobile-drawer__nav a:focus-visible {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .wotu-nav-links {
      display: none !important;
    }
    .wotu-nav-toggle {
      display: flex;
    }
  }

  /* When drawer open: lock body scroll via class on <html> */
  :global(html.wotu-drawer-open) {
    overflow: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    .wotu-mobile-drawer,
    .wotu-nav-toggle span {
      transition: none !important;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.wotu-nav-toggle');
  const drawer = document.getElementById('wotu-mobile-drawer') as HTMLElement | null;
  const closeBtn = drawer?.querySelector<HTMLButtonElement>('.wotu-mobile-drawer__close');
  const drawerLinks = drawer?.querySelectorAll<HTMLAnchorElement>('a');

  const open = () => {
    if (!drawer || !toggle) return;
    drawer.hidden = false;
    document.documentElement.classList.add('wotu-drawer-open');
    toggle.setAttribute('aria-expanded', 'true');
    // Move focus into drawer for keyboard users.
    requestAnimationFrame(() => closeBtn?.focus());
  };

  const close = () => {
    if (!drawer || !toggle) return;
    drawer.hidden = true;
    document.documentElement.classList.remove('wotu-drawer-open');
    toggle.setAttribute('aria-expanded', 'false');
    toggle.focus();
  };

  toggle?.addEventListener('click', open);
  closeBtn?.addEventListener('click', close);
  // Anchor click → close drawer (so mobile users see the section they tapped).
  drawerLinks?.forEach((a) => a.addEventListener('click', () => close()));

  // Esc đóng + Tab focus-trap (giữ keyboard trong drawer khi mở — WCAG).
  document.addEventListener('keydown', (e) => {
    if (!drawer || drawer.hidden) return;
    if (e.key === 'Escape') { close(); return; }
    if (e.key === 'Tab') {
      const list = Array.from(
        drawer.querySelectorAll<HTMLElement>('a[href], button:not([disabled])'),
      ).filter((el) => el.offsetParent !== null);
      if (!list.length) return;
      const first = list[0];
      const last = list[list.length - 1];
      const act = document.activeElement;
      if (e.shiftKey && act === first) { e.preventDefault(); last.focus(); }
      else if (!e.shiftKey && act === last) { e.preventDefault(); first.focus(); }
      else if (!drawer.contains(act)) { e.preventDefault(); first.focus(); }
    }
  });
</script>
