---
import footer from '../data/footer.yml';

interface Props {
  variant?: 'home' | 'inner';
}
const { variant = 'home' } = Astro.props;

interface NavLink { label: string; anchor?: string; route?: string; }
const navLinks = footer.nav.links as NavLink[];
const homeAnchor = variant === 'home' ? '#' : '/';

const links = navLinks.map((l) => {
  if (variant === 'home') {
    return { label: l.label, href: l.route ? l.route : `#${l.anchor}` };
  }
  return { label: l.label, href: l.route ? l.route : `/#${l.anchor}` };
});
---
<nav class="wotu-nav" style="position: fixed; top: 0; left: 0; right: 0; z-index: 50; padding: 20px var(--pad-x); display: flex; justify-content: space-between; align-items: center; mix-blend-mode: difference; color: var(--bone);">
  <a href={homeAnchor} style="font-family: var(--font-display); font-size: 22px; letter-spacing: 0.22em; color: var(--bone);">
    WOTU<span style="color: var(--accent);">.</span>
  </a>
  <div class="wotu-nav-links" style="display: flex; gap: 36px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;">
    {links.map((l) => <a href={l.href}>{l.label}</a>)}
  </div>
</nav>

<style>
  @media (max-width: 768px) {
    .wotu-nav-links { display: none !important; }
  }
</style>
